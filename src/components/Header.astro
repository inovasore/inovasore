---
import { featuredServices } from "../data/services";

const links = [
  { href: "/", label: "Inicio" },
  { href: "/servicios", label: "Servicios", hasDropdown: true },
  { href: "/proyectos", label: "Proyectos" },
  { href: "/nosotros", label: "Nosotros" },
];
---

<header class="header" data-header>
  <div class="header__inner">
    <a href="/" class="logo" aria-label="Inovasore, volver al inicio">
      <img
        src="/Logotipo.svg"
        alt="Logotipo de Inovasore"
        width="48"
        height="48"
      />
    </a>

    <button
      class="header__toggle"
      type="button"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-navigation"
    >
      <span class="material-symbols-rounded">menu</span>
    </button>

    <nav class="nav" id="mobile-navigation">
      <ul class="nav__list">
        {
          links.map((link) => (
            <li
              class={
                link.hasDropdown ? "nav__item nav__item--dropdown" : "nav__item"
              }
            >
              {link.hasDropdown ? (
                <>
                  <div class="nav__link--dropdown-container">
                    <a
                      href={link.href}
                      class="nav__link nav__link--dropdown-text"
                    >
                      {link.label}
                    </a>
                    <button
                      class="nav__link--dropdown-toggle"
                      aria-expanded="false"
                      aria-haspopup="true"
                      aria-label="Abrir menú de servicios"
                      type="button"
                    >
                      <span class="material-symbols-rounded nav__chevron">
                        expand_more
                      </span>
                    </button>
                  </div>
                  <div class="nav__dropdown">
                    <div class="nav__dropdown-inner">
                      {featuredServices.map((service) => (
                        <a href={service.link} class="dropdown__item">
                          <span class="material-symbols-rounded dropdown__icon">
                            {service.icon}
                          </span>
                          <div class="dropdown__content">
                            <h3 class="dropdown__title">{service.title}</h3>
                            <p class="dropdown__description">
                              {service.description}
                            </p>
                          </div>
                        </a>
                      ))}
                    </div>
                  </div>
                </>
              ) : (
                <a href={link.href} class="nav__link">
                  {link.label}
                </a>
              )}
            </li>
          ))
        }
      </ul>
      <a href="/contacto" class="btn-contact btn-contact--mobile">Contactos</a>
    </nav>

    <a href="/contacto" class="btn-contact btn-contact--desktop">Contactos</a>
  </div>
  <div class="header__backdrop" aria-hidden="true"></div>
</header>

<style>
  .header {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    padding: 24px 0;
    background: transparent;
  }

  .header__inner {
    width: clamp(280px, 90vw, 1200px);
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 60px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: #fff;
    user-select: none;
  }

  .logo img {
    height: 36px;
    width: auto;
    display: block;
  }

  .logo__text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    line-height: 1.15;
  }

  .logo__title {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .logo__subtitle {
    font-size: 9px;
    text-transform: uppercase;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.7);
    margin-top: -1px;
  }

  .nav__list {
    display: flex;
    align-items: center;
    list-style: none;
    gap: 46px;
    margin: 0;
    padding: 0;
  }

  .nav__link {
    font-size: 1.125rem;
    color: #fff;
    text-decoration: none;
    font-weight: 400;
    transition: color 0.2s ease;
    white-space: nowrap;
    background: transparent;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .nav__link:hover {
    color: #1b56fd;
  }

  /* Dropdown Styles */
  .nav__item {
    position: relative;
  }

  .nav__item--dropdown {
    position: relative;
  }

  .nav__chevron {
    font-size: 20px;
    transition: transform 0.2s ease;
  }

  .nav__link--dropdown-container {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .nav__link--dropdown-text {
    font-size: 1.125rem;
    color: #fff;
    text-decoration: none;
    font-weight: 400;
    transition: color 0.2s ease;
    white-space: nowrap;
  }

  .nav__link--dropdown-text:hover {
    color: #1b56fd;
  }

  .nav__link--dropdown-toggle {
    background: transparent;
    border: none;
    color: #fff;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s ease;
  }

  .nav__link--dropdown-toggle:hover {
    color: #1b56fd;
  }

  .nav__item--dropdown:hover .nav__chevron {
    transform: rotate(180deg);
  }

  .nav__link--dropdown-wrapper {
    text-decoration: none;
    color: inherit;
  }

  .nav__dropdown {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    background: rgba(15, 23, 42, 0.98);
    backdrop-filter: blur(15px);
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 24px 50px rgba(2, 6, 23, 0.6);
    padding: 12px;
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
    transition:
      opacity 0.25s ease,
      transform 0.25s ease,
      visibility 0.25s;
    transform: translateX(-50%) translateY(-8px);
    min-width: 380px;
    z-index: 1000;
  }

  /* Bridge element to prevent hover break */
  .nav__dropdown::before {
    content: "";
    position: absolute;
    top: -8px;
    left: 0;
    right: 0;
    height: 8px;
    background: transparent;
  }

  .nav__item--dropdown:hover .nav__dropdown,
  .nav__item--dropdown:focus-within .nav__dropdown {
    opacity: 1;
    pointer-events: auto;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .nav__dropdown:hover {
    opacity: 1;
    pointer-events: auto;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .nav__dropdown-inner {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .dropdown__item {
    display: flex;
    gap: 14px;
    padding: 14px 16px;
    border-radius: 12px;
    text-decoration: none;
    color: #fff;
    transition: background 0.2s ease;
    align-items: flex-start;
  }

  .dropdown__item:hover {
    background: rgba(27, 86, 253, 0.1);
  }

  .dropdown__icon {
    font-size: 28px;
    color: #1b56fd;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .dropdown__content {
    flex: 1;
    min-width: 0;
  }

  .dropdown__title {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0 0 4px 0;
    color: #fff;
    line-height: 1.3;
  }

  .dropdown__description {
    font-size: 0.8rem;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
    font-weight: 300;
  }

  .btn-contact {
    background: linear-gradient(90deg, #1b56fd 0%, #133db4 100%);
    color: #fff;
    padding: 10px 28px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 500;
    font-size: 1.125rem;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
    white-space: nowrap;
  }

  .btn-contact:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(27, 86, 253, 0.4);
  }

  .header__toggle {
    display: none;
  }

  .header__backdrop {
    display: none;
  }

  .btn-contact--mobile {
    display: none;
  }

  @media (max-width: 1024px) {
    .header__inner {
      padding: 16px;
      justify-content: space-between;
      gap: 16px;
      max-width: 95%;
    }

    .header__toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 42px;
      height: 42px;
      border-radius: 12px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: transparent;
      color: #fff;
      cursor: pointer;
      transition: all 0.2s ease;
      z-index: 1000;
    }

    .header__toggle:hover {
      background: rgba(255, 255, 255, 0.1);
    }

    .header__toggle:active {
      transform: scale(0.95);
    }

    .nav {
      display: none;
      position: fixed;
      top: 85px;
      left: 50%;
      transform: translateX(-50%);
      width: 90%;
      max-width: 600px;
      background: rgba(15, 23, 42, 0.98);
      backdrop-filter: blur(15px);
      border-radius: 20px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      box-shadow: 0 24px 50px rgb(2 6 23 / 60%);
      padding: 20px;
      z-index: 999;
      opacity: 0;
      pointer-events: none;
      transition:
        opacity 0.3s ease,
        transform 0.3s ease;
      overflow-x: visible;
      overflow-y: auto;
    }
      opacity: 0;
      pointer-events: none;
      transition:
        opacity 0.3s ease,
        transform 0.3s ease;
    }

    .header.header--open .nav {
      display: block;
      opacity: 1;
      pointer-events: auto;
    }

    .header__backdrop {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgb(0 0 0 / 50%);
      z-index: 998;
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .header.header--open .header__backdrop {
      display: block;
      opacity: 1;
    }

    .nav__list {
      flex-direction: column;
      align-items: stretch;
      gap: 8px;
    }

    /* Mobile dropdown styles */
    .nav__item--dropdown {
      position: relative;
    }

    .nav__link--dropdown-container {
      display: flex;
      width: 100%;
      justify-content: space-between;
      align-items: center;
      padding: 12px 16px;
      border-radius: 12px;
      background: transparent;
    }

    .nav__link--dropdown-text {
      flex: 1;
    }

    .nav__link--dropdown-toggle {
      padding: 4px;
    }

    .nav__dropdown {
      position: static;
      transform: none;
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      background: transparent;
      border: none;
      box-shadow: none;
      padding: 8px 0 0 0;
      min-width: auto;
      width: 100%;
      margin-top: 0;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
    }

    /* Hide dropdown toggle button on mobile */
    .nav__link--dropdown-toggle {
      display: none;
    }

    /* Make services link non-clickable on mobile (just label) */
    .nav__link--dropdown-text {
      pointer-events: none;
      opacity: 0.7;
      font-size: 0.95rem;
    }

    /* Show dropdown always expanded on mobile */
    .nav__dropdown {
      position: static;
      transform: none;
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      background: transparent;
      border: none;
      box-shadow: none;
      padding: 0;
      margin: 8px 0;
      max-height: none;
      overflow: visible;
    }

    .nav__dropdown-inner {
      padding: 0;
      width: 100%;
    }

    /* Simple dropdown items - no accordion */
    .dropdown__item {
      display: flex;
      padding: 10px 16px 10px 24px;
      margin: 0;
      background: transparent;
      gap: 10px;
      align-items: center;
      border-radius: 12px;
      width: 100%;
      text-decoration: none;
      color: rgba(255, 255, 255, 0.9);
      font-size: 0.95rem;
      transition: background 0.2s ease;
      box-sizing: border-box;
    }

    .dropdown__item:hover {
      background: rgba(27, 86, 253, 0.1);
    }

    .dropdown__icon {
      font-size: 18px;
      flex-shrink: 0;
      color: #1b56fd;
    }

    .dropdown__content {
      flex: 1;
      min-width: 0;
    }

    .dropdown__title {
      font-size: 0.9rem;
      margin: 0;
      line-height: 1.3;
      color: rgba(255, 255, 255, 0.9);
      white-space: normal;
      word-break: break-word;
    }

    .dropdown__description {
      display: none;
    }

    .nav__list li {
      width: 100%;
    }

    .nav__item {
      width: 100%;
    }

    .nav__link {
      display: block;
      padding: 12px 16px;
      border-radius: 12px;
      background: transparent;
      transition: all 0.2s ease;
      width: 100%;
    }

    .nav__link:hover {
      background: rgb(27 86 253 / 10%);
    }

    .btn-contact--desktop {
      display: none;
    }

    .btn-contact--mobile {
      display: block;
      width: 100%;
      text-align: center;
      margin-top: 16px;
    }

    .logo__title {
      font-size: 22px;
    }

    .logo__subtitle {
      font-size: 10px;
    }

    .logo img {
      height: 36px;
    }
  }
</style>

<script>
  window.addEventListener("DOMContentLoaded", () => {
    const header = document.querySelector("[data-header]");
    if (!header) return;

    const toggle = header.querySelector(".header__toggle");
    const nav = header.querySelector(".nav");
    const backdrop = header.querySelector(".header__backdrop");

    let menuOpen = false;

    const openMenu = () => {
      menuOpen = true;
      header.classList.add("header--open");
      toggle?.setAttribute("aria-expanded", "true");
      toggle?.setAttribute("aria-label", "Cerrar menú");
      document.body.style.overflow = "hidden";
    };

    const closeMenu = () => {
      menuOpen = false;
      header.classList.remove("header--open");
      toggle?.setAttribute("aria-expanded", "false");
      toggle?.setAttribute("aria-label", "Abrir menú");
      document.body.style.overflow = "";
    };

    toggle?.addEventListener("click", () => {
      if (menuOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    backdrop?.addEventListener("click", closeMenu);

    nav?.addEventListener("click", (e) => {
      if (e.target instanceof Element && e.target.closest("a")) {
        closeMenu();
      }
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && menuOpen) {
        e.preventDefault();
        closeMenu();
      }
    });

    // Dropdown toggle for mobile
    const dropdownToggles = header.querySelectorAll(
      ".nav__link--dropdown-toggle",
    );
    dropdownToggles.forEach((dropdownToggle) => {
      dropdownToggle.addEventListener("click", (e) => {
        e.preventDefault();
        const parent = dropdownToggle.closest(".nav__item--dropdown");
        if (!parent) return;

        const isActive = parent.classList.contains("active");

        // Close all other dropdowns
        header.querySelectorAll(".nav__item--dropdown").forEach((item) => {
          if (item !== parent) {
            item.classList.remove("active");
            const btn = item.querySelector(".nav__link--dropdown");
            btn?.setAttribute("aria-expanded", "false");
          }
        });

        // Toggle current dropdown
        if (isActive) {
          parent.classList.remove("active");
          dropdownToggle.setAttribute("aria-expanded", "false");
        } else {
          parent.classList.add("active");
          dropdownToggle.setAttribute("aria-expanded", "true");
        }
      });
    });
  });
</script>
