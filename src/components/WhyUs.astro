---
import { whyUsCards } from "../data/why-us";
---

<section class="why" id="nosotros">
  <div class="section-inner section-inner--center why__inner">
    <div
      class="section-tag why__tag reveal"
      style="--reveal-delay:.04s;--reveal-duration:.45s;--reveal-distance:10px"
    >
      ¿Por qué nosotros?
    </div>

    <h2
      class="why__title reveal"
      style="--reveal-delay:.12s;--reveal-duration:.55s;--reveal-distance:12px"
    >
      Por qué Inovasore <span class="highlight">se destaca.</span>
    </h2>

    <p
      class="why__subtitle reveal"
      style="--reveal-delay:.2s;--reveal-duration:.45s;--reveal-distance:10px"
    >
      Descubra por qué Inovasore se destaca en ofrecer soluciones de diseño y
      desarrollo web innovadoras y centradas en el cliente.
    </p>

    <div class="why__grid">
      {
        whyUsCards.map((card, index) => {
          const style = [
            `--reveal-delay:${(0.06 + index * 0.06).toFixed(2)}s`,
            "--reveal-duration:.45s",
            "--reveal-distance:12px",
          ].join(";");

          return (
            <article class="why__card reveal" style={style}>
              <div class="why__icon" aria-hidden="true">
                <span class="material-symbols-rounded" aria-hidden="true">
                  {card.icon}
                </span>
              </div>
              <h3 class="why__card-title">{card.title}</h3>
              <p class="why__card-desc">{card.description}</p>
            </article>
          );
        })
      }
    </div>
  </div>

  <style>
    .why {
      position: relative;
      overflow: hidden;
      isolation: isolate;
      padding: clamp(160px, 20vh, 220px) 0 60px 0;
      background: var(--color-bg);
      color: var(--color-text);
    }

    .why__title {
      font-size: clamp(1.8rem, 3.2vw + 0.6rem, 2.5rem);
      font-weight: 600;
      line-height: 1.15;
      margin: clamp(12px, 2.4vh, 18px) auto clamp(10px, 2.4vh, 18px);
      max-width: 28ch;
    }

    .why__title .highlight {
      background-image: linear-gradient(
        90deg,
        #26d2f8,
        #23b2ff,
        #0973e1 70%,
        #3b5bff 100%
      );
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .why__subtitle {
      color: color-mix(in oklab, var(--color-text) 62%, transparent);
      font-size: clamp(1rem, 0.9rem + 0.35vw, 1.1rem);
      max-width: 60ch;
      margin: 0 auto clamp(26px, 6vh, 40px);
      font-weight: 300;
    }

    .why__grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: clamp(18px, 2.6vw, 26px);
      margin-top: clamp(28px, 6vh, 44px);
    }

    .why__card {
      position: relative;
      text-align: left;
      padding: 20px 22px;
      border-radius: 18px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: linear-gradient(
        180deg,
        rgba(12, 14, 22, 0.92),
        rgba(12, 14, 22, 0.86)
      );
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
      transition:
        transform 0.18s ease,
        box-shadow 0.25s ease,
        border-color 0.25s ease;
    }

    .why__card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 18px;
      height: 4px;
      width: 76px;
      border-radius: 0 0 8px 8px;
      pointer-events: none;
      z-index: 2;
      background: linear-gradient(90deg, #0973e1 0%, #0446ba 100%);
      box-shadow: 0 8px 18px rgba(9, 115, 225, 0.35);
      opacity: 0.95;
    }

    /* .why__card::after is merged here from dark override */
    .why__card::after {
      content: "";
      position: absolute;
      inset: -1px;
      border-radius: inherit;
      pointer-events: none;
      z-index: 1;
      background:
        radial-gradient(
          420px 260px at 110% 120%,
          rgba(9, 115, 225, 0.12),
          transparent 60%
        ),
        radial-gradient(
          300px 220px at -8% 12%,
          rgba(9, 115, 225, 0.06),
          transparent 72%
        );
      mix-blend-mode: screen;
      opacity: 0.24;
      transition: opacity 0.25s ease;
    }

    .why__card:hover {
      transform: translateY(-2px);
      border-color: rgba(59, 130, 246, 0.35);
      box-shadow:
        0 10px 30px rgba(0, 0, 0, 0.25),
        inset 0 1px 0 rgba(255, 255, 255, 0.04);
      filter: saturate(112%) brightness(1.02);
    }

    .why__card:hover::after {
      opacity: 0.3;
    }

    .why__icon {
      position: relative;
      width: 45px;
      height: 45px;
      border-radius: 10px;
      display: grid;
      place-items: center;
      font-size: 20px;
      margin-bottom: 8px;
      background: var(--color-primary);
      color: #fff;
      border: none;
      box-shadow: none;
      transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .why__icon .material-symbols-rounded {
      transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .why__card:hover .why__icon {
      transform: scale(1.1);
    }

    .why__card:nth-child(1):hover .why__icon .material-symbols-rounded,
    .why__card:nth-child(4):hover .why__icon .material-symbols-rounded {
      animation: bounce-rotate 0.6s ease;
    }

    .why__card:nth-child(2):hover .why__icon .material-symbols-rounded,
    .why__card:nth-child(5):hover .why__icon .material-symbols-rounded {
      animation: pulse-scale 0.5s ease;
    }

    .why__card:nth-child(3):hover .why__icon .material-symbols-rounded,
    .why__card:nth-child(6):hover .why__icon .material-symbols-rounded {
      animation: shake 0.5s ease;
    }

    @keyframes bounce-rotate {
      0%,
      100% {
        transform: rotate(0deg) scale(1);
      }
      25% {
        transform: rotate(-10deg) scale(1.15);
      }
      75% {
        transform: rotate(10deg) scale(1.15);
      }
    }

    @keyframes pulse-scale {
      0%,
      100% {
        transform: scale(1);
      }
      50% {
        transform: scale(1.25);
      }
    }

    @keyframes shake {
      0%,
      100% {
        transform: translateX(0);
      }
      25% {
        transform: translateX(-4px) rotate(-5deg);
      }
      75% {
        transform: translateX(4px) rotate(5deg);
      }
    }

    .why__card-title {
      font-size: 1.15rem;
      font-weight: 600;
      color: #fff;
    }

    .why__card-desc {
      color: #d6e0ef;
      font-size: 0.98rem;
      margin-top: 0.35rem;
      font-weight: 300;
      line-height: 1.4;
    }

    @media (max-width: 840px) {
      .why__grid {
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      }
    }
  </style>
</section>
