---
import { heroContent } from "../data/hero";
import { Image } from "astro:assets";

const { title, tagline, subtitle, works } = heroContent;
const [primaryWork, ...secondaryWorks] = works;
---

<section class="hero">
  <div class="hero__glow" aria-hidden="true"></div>
  <div class="hero__inner">
    <div
      class="announcement reveal"
      style="--reveal-delay:.08s;--reveal-duration:.48s;--reveal-distance:10px"
    >
      <svg class="announcement__svg" preserveAspectRatio="none">
        <rect fill="none" width="100%" height="100%" rx="50%" ry="50%"></rect>
      </svg>
      <!-- <div class="announcement__dot"></div> -->
      <div class="announcement__content">
        <span class="announcement__tag">{tagline}</span>
        <a
          class="announcement__cta"
          href="/contacto"
          aria-label="Ir a contacto"
        >
          <img src="/Bar01.svg" alt="" width="28" height="28" />
        </a>
      </div>
    </div>

    <h1
      class="hero__title reveal"
      style="--reveal-delay:.16s;--reveal-duration:.55s;--reveal-distance:14px"
      set:html={title}
    />

    <p
      class="hero__subtitle reveal"
      style="--reveal-delay:.26s;--reveal-duration:.45s;--reveal-distance:10px"
    >
      {subtitle}
    </p>

    <div class="hero__actions">
      <a
        class="btn-hero-primary reveal"
        href="/contacto"
        style="--reveal-delay:.34s;--reveal-duration:.45s"
      >
        Quiero crecer
        <span class="material-symbols-rounded" aria-hidden="true"
          >chevron_right</span
        >
      </a>
      <div
        class="btn-outline-wrapper reveal"
        style="--reveal-delay:.42s;--reveal-duration:.45s"
      >
        <svg class="moving-border__svg" preserveAspectRatio="none">
          <rect fill="none" width="100%" height="100%" rx="50%" ry="50%"></rect>
        </svg>
        <div class="moving-border__dot"></div>
        <a class="btn-hero-outline" href="/servicios"> Servicios </a>
      </div>
    </div>
  </div>
  <div class="carousel carousel--auto" data-speed="35">
    <div class="carousel__track" tabindex="-1">
      <figure class="carousel__item">
        <Image
          src={primaryWork}
          alt="Proyecto destacado 1"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          width={440}
          height={275}
        />
      </figure>
      {
        secondaryWorks.map((src, i) => (
          <figure class="carousel__item">
            <Image
              src={src}
              alt={`Proyecto ${i + 2}`}
              loading="lazy"
              decoding="async"
              width={440}
              height={275}
            />
          </figure>
        ))
      }
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    if (
      window.matchMedia &&
      window.matchMedia("(prefers-reduced-motion: reduce)").matches
    )
      return;

    // Glass spotlight — rAF-throttled, cleaned up on page transitions
    var hero = document.querySelector(".hero");
    if (hero) {
      var spotRaf = false;
      var spotX = 0,
        spotY = 0;

      function applySpot() {
        hero.style.setProperty("--mouse-x", spotX + "%");
        hero.style.setProperty("--mouse-y", spotY + "%");
        spotRaf = false;
      }

      function onHeroMove(e) {
        var rect = hero.getBoundingClientRect();
        spotX = ((e.clientX - rect.left) / rect.width) * 100;
        spotY = ((e.clientY - rect.top) / rect.height) * 100;
        if (!spotRaf) {
          spotRaf = true;
          requestAnimationFrame(applySpot);
        }
      }

      hero.addEventListener("mousemove", onHeroMove);
      document.addEventListener(
        "astro:before-swap",
        function () {
          hero.removeEventListener("mousemove", onHeroMove);
        },
        { once: true },
      );
    }

    // Collect all moving border pairs: announcement + Servicios button
    const pairs = [];

    // const announcement = document.querySelector(".announcement");
    // if (announcement) {
    //   const rect = announcement.querySelector(".announcement__svg rect");
    //   const dot = announcement.querySelector(".announcement__dot");
    //   if (rect && dot) pairs.push({ rect, dot, duration: 6500 });
    // }

    document
      .querySelectorAll(".btn-outline-wrapper")
      .forEach(function (wrapper) {
        var rect = wrapper.querySelector(".moving-border__svg rect");
        var dot = wrapper.querySelector(".moving-border__dot");
        if (rect && dot) pairs.push({ rect, dot, duration: 3000 });
      });

    if (!pairs.length) return;

    let rafId;

    function animate(time) {
      pairs.forEach(function (p) {
        var length = p.rect.getTotalLength();
        if (length) {
          var pxPerMs = length / p.duration;
          var progress = (time * pxPerMs) % length;
          var point = p.rect.getPointAtLength(progress);
          p.dot.style.transform =
            "translate(" +
            point.x +
            "px," +
            point.y +
            "px) translate(-50%,-50%)";
        }
      });
      rafId = requestAnimationFrame(animate);
    }

    rafId = requestAnimationFrame(animate);

    document.addEventListener(
      "astro:before-swap",
      function () {
        cancelAnimationFrame(rafId);
      },
      { once: true },
    );
  })();
</script>

<script>
  const setupAutoCarousels = () => {
    // Mobile check removed to allow animation on all devices

    if (
      window.matchMedia &&
      window.matchMedia("(prefers-reduced-motion: reduce)").matches
    ) {
      return;
    }

    const cleanups: (() => void)[] = [];

    document
      .querySelectorAll(".carousel.carousel--auto")
      .forEach((carousel) => {
        const track = carousel.querySelector(".carousel__track") as HTMLElement;
        if (!track || track.dataset.running === "true") return;
        track.dataset.running = "true";

        const originals = Array.from(track.children) as HTMLElement[];

        // Calculate dimensions once to avoid reflow in loop
        let gap = parseFloat(getComputedStyle(track).gap || "0") || 0;
        let itemWidths = originals.map(
          (node) => node.getBoundingClientRect().width + gap,
        );

        const ensureCoverage = () => {
          gap = parseFloat(getComputedStyle(track).gap || "0") || 0;
          const required = carousel.clientWidth * 2;
          let total = 0;

          // Re-calculate current total width
          const currentChildren = Array.from(track.children) as HTMLElement[];
          currentChildren.forEach((child) => {
            total += child.getBoundingClientRect().width + gap;
          });

          // Only clone if needed
          let guard = 0;
          while (total < required && guard++ < 12) {
            originals.forEach((node) => {
              const clone = node.cloneNode(true) as HTMLElement;
              track.appendChild(clone);
              // Optimistically add width to total to avoid reading DOM again immediately
              total += node.getBoundingClientRect().width + gap;
            });
          }
        };

        // Initial coverage check
        ensureCoverage();

        // Debounced resize handler
        let resizeTimeout: ReturnType<typeof setTimeout>;
        const resizeHandler = () => {
          clearTimeout(resizeTimeout);
          resizeTimeout = setTimeout(() => {
            ensureCoverage();
          }, 100);
        };
        window.addEventListener("resize", resizeHandler, { passive: true });

        // Ensure images are loaded before final measurement
        track.querySelectorAll("img").forEach((img) => {
          if (img.complete) return;
          img.addEventListener("load", () => ensureCoverage(), { once: true });
        });

        let inView = true;
        let observer: IntersectionObserver;

        const speed = Number((carousel as HTMLElement).dataset.speed || 28);
        let offset = 0;
        let last = 0;
        let frameId = 0;

        const shouldRun = () => !document.hidden && inView;

        const stop = () => {
          if (frameId) {
            cancelAnimationFrame(frameId);
            frameId = 0;
          }
          last = 0;
        };

        const step = (now: number) => {
          if (!shouldRun()) {
            stop();
            return;
          }

          if (!last) {
            last = now;
          }

          const delta = (now - last) / 1000;
          last = now;

          offset -= speed * delta;

          // For left-to-right scrolling visually, we decrement offset (move left)
          // and move first element to end when it goes off screen
          let first = track.firstElementChild as HTMLElement;
          if (first) {
            if (Math.abs(offset) > 200) {
              const width = first.getBoundingClientRect().width + gap;
              if (Math.abs(offset) >= width) {
                track.appendChild(first);
                offset += width;
              }
            }
          }

          track.style.transform = `translate3d(${offset}px,0,0)`;
          frameId = requestAnimationFrame(step);
        };

        const start = () => {
          if (frameId || !shouldRun()) return;
          last = performance.now();
          frameId = requestAnimationFrame(step);
        };

        const updateRunner = () => {
          if (shouldRun()) {
            start();
          } else {
            stop();
          }
        };

        const visibilityHandler = () => updateRunner();
        document.addEventListener("visibilitychange", visibilityHandler);

        if ("IntersectionObserver" in window) {
          observer = new IntersectionObserver(
            (entries) => {
              const visible = entries.some((entry) => entry.isIntersecting);
              if (visible !== inView) {
                inView = visible;
                updateRunner();
              }
            },
            { threshold: 0.01 },
          );
          observer.observe(carousel);
        }

        updateRunner();

        const cleanup = () => {
          stop();
          window.removeEventListener("resize", resizeHandler);
          document.removeEventListener("visibilitychange", visibilityHandler);
          observer?.disconnect();
          delete track.dataset.running;
          track.style.transform = `translate3d(${-offset}px,0,0)`;
        };

        cleanups.push(cleanup);
      });

    if (cleanups.length) {
      const runCleanups = () => {
        cleanups.splice(0).forEach((fn) => {
          try {
            fn();
          } catch (_) {}
        });
      };
      document.addEventListener("astro:before-swap", runCleanups, {
        once: true,
      });
      window.addEventListener("beforeunload", runCleanups, { once: true });
    }
  };

  const scheduleCarousels = () => {
    const start = () => setupAutoCarousels();
    if ("requestIdleCallback" in window) {
      requestIdleCallback(start, { timeout: 1200 });
    } else {
      setTimeout(start, 180);
    }
  };

  if (document.readyState === "complete") {
    scheduleCarousels();
  } else {
    window.addEventListener("load", scheduleCarousels, { once: true });
  }

  document.addEventListener("astro:page-load", scheduleCarousels);
</script>

<style>
  :root {
    --nav-h: 72px;
    --nav-gap: 12px;

    --indigo: #6366f1;
    --blue: #3b82f6;
    --cyan: #0ea5e9;
  }

  .navbar {
    position: fixed;
    z-index: 200;
  }
  .hero {
    z-index: 0;
  }

  .hero {
    position: relative;
    padding: calc(var(--nav-h, 72px) + 120px) 0 var(--section-padding-y);
    min-height: 86vh;
    background: var(--color-bg);
    color: var(--color-text);
    overflow: hidden;
    --mouse-x: 50%;
    --mouse-y: 50%;
  }

  .hero__glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background: radial-gradient(
      700px circle at var(--mouse-x) var(--mouse-y),
      rgba(27, 86, 253, 0.13),
      transparent 55%
    );
    opacity: 0;
    transition: opacity 0.4s ease;
    will-change: background;
  }

  .hero:hover .hero__glow {
    opacity: 1;
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      url("/Vectorbg.svg") center center / cover,
      url("/bg-hero.svg") no-repeat center top / 1600px auto;
    opacity: 0.95;
    pointer-events: none;
    z-index: -1;
    will-change: opacity;
  }
  .dark .hero::before {
    opacity: 1;
  }

  .hero__inner {
    width: clamp(280px, 92vw, 1200px);
    margin: 0 auto;
    text-align: center;
  }

  /* ── Announcement with Moving Border ── */
  .announcement {
    position: relative;
    display: inline-flex;
    border-radius: 999px;
    padding: 0;
    margin-bottom: 20px;
    background: transparent;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.18);
  }

  .announcement__svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .announcement__dot {
    position: absolute;
    top: 0;
    left: 0;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      #5b9cff 0%,
      #3b82f6 15%,
      #1b56fd 30%,
      rgba(27, 86, 253, 0.4) 50%,
      rgba(27, 86, 253, 0.1) 70%,
      transparent 100%
    );
    filter: blur(4px);
    pointer-events: none;
    z-index: 0;
    will-change: transform;
  }

  .announcement__content {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.55rem 0.85rem;
    border-radius: 999px;
    background: #0d1a3e;
    color: var(--color-text);
  }

  .announcement__tag {
    font-weight: 400;
    font-size: 0.95rem;
  }

  .announcement__cta {
    display: inline-grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border-radius: 999px;
    background: var(--color-primary);
    color: #fff;
    text-decoration: none;
    font-weight: 400;
    line-height: 1;
  }

  .hero__title {
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: 0.2px;
    font-size: clamp(1.6rem, 2.5vw + 1rem, 4.5rem);
    margin: 0.35rem auto 0;
    max-width: 100%;
  }

  .hero__subtitle {
    color: var(--color-text-muted, #6b7280);
    font-size: clamp(1.05rem, 0.9rem + 0.4vw, 1.2rem);
    margin: 8px auto 24px;
    max-width: 60ch;
    font-weight: 400;
  }

  .hero__actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: clamp(45px, 8vh, 75px);
  }

  .btn-cta {
    font-weight: 500;
    background: linear-gradient(90deg, #1b56fd 0%, #133db4 100%);
    box-shadow: 0 4px 12px rgba(27, 86, 253, 0.3);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .btn-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(27, 86, 253, 0.4);
  }

  .btn-cta:active {
    transform: translateY(0);
    box-shadow: 0 4px 12px rgba(27, 86, 253, 0.3);
  }

  .btn-hero-primary {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 6px !important;
    padding: 14px 28px !important;
    border-radius: 999px !important;
    background: linear-gradient(90deg, #1b56fd 0%, #133db4 100%) !important;
    color: #fff !important;
    text-decoration: none !important;
    font-weight: 500 !important;
    font-size: 1rem !important;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease !important;
    box-shadow: 0 4px 12px rgba(27, 86, 253, 0.3) !important;
    border: 1.5px solid transparent !important;
  }

  .btn-hero-primary .material-symbols-rounded {
    font-size: 1.2rem;
  }

  .btn-hero-primary:hover {
    transform: translateY(-2px) !important;
    box-shadow: 0 8px 20px rgba(27, 86, 253, 0.4) !important;
    background: linear-gradient(90deg, #1b56fd 0%, #133db4 100%) !important;
  }

  .btn-hero-primary:active {
    transform: translateY(0) !important;
  }

  .btn-wrapper {
    position: relative;
    display: inline-flex;
  }

  .btn-outline-wrapper {
    position: relative;
    display: inline-flex;
    border-radius: 999px;
    padding: 1.4px;
    background: rgba(255, 255, 255, 0.08);
    overflow: hidden;
  }

  .moving-border__svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .moving-border__dot {
    position: absolute;
    top: 0;
    left: 0;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      #5b9cff 0%,
      #3b82f6 15%,
      #1b56fd 30%,
      rgba(27, 86, 253, 0.4) 50%,
      rgba(27, 86, 253, 0.1) 70%,
      transparent 100%
    );
    filter: blur(4px);
    pointer-events: none;
    z-index: 0;
    will-change: transform;
  }

  .btn-hero-outline {
    position: relative !important;
    z-index: 1 !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    padding: 14px 28px !important;
    border-radius: 999px !important;
    background: var(--color-bg, #0a0b10) !important;
    color: #fff !important;
    text-decoration: none !important;
    font-weight: 400 !important;
    font-size: 1rem !important;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease !important;
    border: none !important;
  }

  .border-line {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 3;
    filter: drop-shadow(0 0 8px rgba(59, 130, 246, 0.9))
      drop-shadow(0 0 15px rgba(37, 99, 235, 0.6));
  }

  .line-path {
    stroke-dasharray: 50 318;
    stroke-dashoffset: 0;
    animation: travelLine 3s linear infinite;
  }

  @keyframes travelLine {
    0% {
      stroke-dashoffset: 0;
    }
    100% {
      stroke-dashoffset: -368;
    }
  }

  .btn-outline-wrapper:hover {
    transform: translateY(-2px);
  }

  .btn-outline-wrapper:active {
    transform: translateY(0);
  }

  /* Global styles for injected HTML content */
  :global(.mobile-br) {
    display: none;
  }

  :global(.desktop-br) {
    display: block;
  }

  @media (max-width: 768px) {
    :global(.mobile-nowrap) {
      white-space: nowrap;
      display: inline-block;
    }
    :global(.mobile-br) {
      display: block;
    }
    :global(.desktop-br) {
      display: none;
    }
    .announcement {
      margin-bottom: 12px;
    }

    .announcement__content {
      gap: 0.5rem;
      padding: 6px 6px 6px 16px;
    }

    .announcement__tag {
      font-size: clamp(0.78rem, 3vw, 0.92rem);
      line-height: 1.2;
      text-align: left;
    }

    .announcement__cta {
      width: 30px;
      height: 30px;
      flex: 0 0 30px;
      font-size: 1rem;
    }

    .hero__actions {
      flex-direction: row;
      gap: 0.65rem;
      align-items: center;
      justify-content: center;
      margin-inline: auto;
    }

    .hero__actions .btn-cta {
      width: auto;
      min-width: 180px;
      padding-inline: 1rem;
    }

    .btn-wrapper {
      display: none !important;
    }

    .btn-hero-primary,
    .btn-hero-outline {
      padding: 12px 20px !important;
      font-size: 0.95rem !important;
    }

    .status {
      justify-content: center;
      font-size: 0.9rem;
      text-align: center;
    }
  }

  .status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-muted, #6b7280);
  }
  .dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    display: inline-block;
    background: radial-gradient(circle at 30% 30%, #22c55e, #16a34a);
    box-shadow: 0 0 10px rgba(34, 197, 94, 0.6);
  }

  .carousel {
    position: relative;
    width: 100vw;
    max-width: none;
    margin-top: 12px;
    left: 50%;
    transform: translateX(-50%);
    overflow: hidden;
  }
  .carousel__track {
    display: flex;
    gap: 18px;
    will-change: transform;
    transform: translate3d(0, 0, 0);
    scroll-behavior: auto !important;
  }

  .carousel__item {
    flex: 0 0 clamp(260px, 26vw, 440px);
    aspect-ratio: 16 / 10;
    border-radius: var(--radius-lg);
    position: relative;
    border: 1px solid color-mix(in oklab, var(--color-primary) 26%, transparent);
    overflow: hidden;
  }
  .carousel__item img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transform: translateZ(0);
  }

  /* Mobile overrides removed to keep marquee animation */
  /*
  @media (max-width: 768px) {
    .carousel {
      width: 100%;
      max-width: 100%;
      margin-left: auto;
      margin-right: auto;
      left: auto;
      transform: none;
      overflow-x: auto;
      padding-inline: 16px;
      scroll-snap-type: x mandatory;
    }
    .carousel__track {
      gap: 14px;
      padding-bottom: 6px;
      width: max-content;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
    }
    .carousel__item {
      scroll-snap-align: center;
    }
    .carousel::-webkit-scrollbar {
      display: none;
    }
    .carousel {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
  }
  */

  @supports not (color: color-mix(in oklab, black 50%, white)) {
    .announcement__content {
      background: #0a0b10;
    }
    .carousel__item {
      border-color: rgba(99, 102, 241, 0.26);
    }
  }
</style>
