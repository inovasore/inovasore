---
import { heroContent } from "../data/hero";

const { title, tagline, subtitle, works } = heroContent;
---

<section class="hero">
  <div class="hero__inner">
    <div class="pill reveal" style="--reveal-delay:.08s;--reveal-duration:.48s;--reveal-distance:10px;--pill-weight:400">
      <span class="pill__text">{tagline}</span>
      <a class="pill__cta" href="/contacto" aria-label="Ir a contacto">&rarr;</a>
    </div>

    <h1 class="hero__title reveal" style="--reveal-delay:.16s;--reveal-duration:.55s;--reveal-distance:14px">
      {title}
    </h1>

    <p class="hero__subtitle reveal" style="--reveal-delay:.26s;--reveal-duration:.45s;--reveal-distance:10px">
      {subtitle}
    </p>

    <div class="hero__actions">
      <a class="btn btn--lg btn-cta reveal" href="/contacto" style="--reveal-delay:.34s;--reveal-duration:.45s">Contáctanos</a>
      <div class="status reveal" style="--reveal-delay:.42s;--reveal-duration:.45s">
        <span class="dot"></span><span>Agenda tu asesorí­a gratuita</span>
      </div>
    </div>
  </div>

  <div class="carousel carousel--auto" data-speed="35">
    <div class="carousel__track" tabindex="-1">
      {works.map((src, i) => (
        <figure class="carousel__item">
          <img
            src={src}
            alt={`Proyecto ${i + 1}`}
            loading={i === 0 ? 'eager' : 'lazy'}
            decoding="async"
            fetchpriority={i === 0 ? 'high' : 'auto'}
            sizes="(min-width: 1024px) 30vw, 80vw"
          />
        </figure>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  window.addEventListener('DOMContentLoaded', () => {
    if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      return;
    }

    const cleanups = [];

    document.querySelectorAll('.carousel.carousel--auto').forEach((carousel) => {
      const track = carousel.querySelector('.carousel__track');
      if (!track || track.dataset.running === 'true') return;
      track.dataset.running = 'true';

      const originals = Array.from(track.children);
      const gap = () => parseFloat(getComputedStyle(track).gap || '0') || 0;
      const widthWithGap = (node) => node.getBoundingClientRect().width + gap();

      const ensureCoverage = () => {
        const required = carousel.clientWidth * 2;
        let total = 0;
        Array.from(track.children).forEach((child) => {
          total += widthWithGap(child);
        });
        let guard = 0;
        while (total < required && guard++ < 12) {
          originals.forEach((node) => {
            const clone = node.cloneNode(true);
            track.appendChild(clone);
            total += widthWithGap(clone);
          });
        }
      };

      ensureCoverage();
      window.addEventListener('resize', ensureCoverage);

      track.querySelectorAll('img').forEach((img) => {
        img.addEventListener('load', () => ensureCoverage(), { once: true });
      });

      let inView = true;
      let observer;
      if ('IntersectionObserver' in window) {
        observer = new IntersectionObserver((entries) => {
          inView = entries.some((entry) => entry.isIntersecting);
        }, { threshold: 0.01 });
        observer.observe(carousel);
      }

      const speed = Number(carousel.dataset.speed || 28);
      let offset = 0;
      let last = performance.now();
      let frameId = 0;

      const step = (now) => {
        const delta = (now - last) / 1000;
        last = now;

        if (!document.hidden && inView) {
          offset += speed * delta;
          let first = track.firstElementChild;
          while (first) {
            const width = widthWithGap(first);
            if (offset < width) break;
            track.appendChild(first);
            offset -= width;
            first = track.firstElementChild;
          }
        }

                track.style.transform = `translate3d(${-offset}px,0,0)`;
        frameId = requestAnimationFrame(step);
      };

      frameId = requestAnimationFrame(step);

      const cleanup = () => {
        cancelAnimationFrame(frameId);
        window.removeEventListener('resize', ensureCoverage);
        observer?.disconnect();
                track.style.transform = `translate3d(${-offset}px,0,0)`;
        track.dataset.running = '';
      };

      cleanups.push(cleanup);
    });

    if (cleanups.length) {
      const runCleanups = () => {
        cleanups.splice(0).forEach((fn) => {
          try { fn(); } catch (_) {}
        });
      };
      document.addEventListener('astro:before-swap', runCleanups, { once: true });
      window.addEventListener('beforeunload', runCleanups, { once: true });
    }
  });
</script>

<style>
  :root {
    --nav-h: 72px;
    --nav-gap: 12px;

    --indigo: #6366f1;
    --blue:   #3b82f6;
    --cyan:   #0ea5e9;
  }

  .navbar { position: fixed; z-index: 200; }
  .hero { z-index: 0; }

  .hero {
    position: relative;
    padding: max(calc(var(--section-padding-y) + 24px), calc(var(--nav-h,72px) + 12px)) 0 var(--section-padding-y);
    min-height: 86vh;
    background: var(--color-bg);
    color: var(--color-text);
    overflow: hidden;
  }

  .hero::before {
    content:"";
    position:absolute; inset:0;
    background: url("/bg-hero.svg") no-repeat center top;
    background-size: 1600px auto;
    opacity:.95;
    pointer-events:none;
    z-index: -1;
    filter: drop-shadow(0 40px 120px rgba(37,99,235,.25));
  }
  .dark .hero::before {
    opacity: 1;
    filter: drop-shadow(0 50px 160px rgba(59,130,246,.35));
  }

  .hero__inner {
    width: clamp(280px, 90vw, 1100px);
    margin: 0 auto;
    text-align: center;
  }

  .pill {
    display:inline-flex; align-items:center; gap:.75rem;
    padding:.6rem .9rem;
    border-radius:999px;
    border:1px solid var(--border);
    background: color-mix(in oklab, var(--surface, #f3f4f6) 60%, transparent);
    backdrop-filter: blur(6px);
    color: var(--color-text);
    margin-bottom: 18px;
  }
  .pill__text { font-weight: var(--pill-weight, 400); }
  .pill__cta {
    display:inline-grid; place-items:center;
    width:28px; height:28px; border-radius:999px;
    background: var(--color-primary); color:#fff; text-decoration:none;
    font-weight:400; line-height:1;
  }

  .hero__title {
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: .2px;
    font-size: clamp(1.8rem, 3.1vw + 1rem, 3.1rem);
    margin: .35rem auto .6rem;
    max-width: 22ch;
  }

  .hero__subtitle {
    color: var(--color-text-muted, #6b7280);
    font-size: clamp(1.05rem, .9rem + .4vw, 1.2rem);
    margin: 2rem auto 1.25rem;
    max-width: 60ch;
    font-weight: 400;
  }

  .hero__actions {
    display:flex; align-items:center; justify-content:center; gap:1rem;
    margin-bottom: clamp(18px, 4vh, 34px);
  }

  .btn-cta {  
    font-weight: 400;
    position: relative;
    overflow: hidden;
    background: linear-gradient(90deg, var(--color-primary-dark) 0%, var(--color-primary) 50%, var(--color-primary-dark) 100%);
    background-size: 200% 100%;
    animation: cta-gradient 5.5s ease-in-out infinite;
    box-shadow: 0 6px 16px rgba(37, 99, 235, .28);
    transform: translateZ(0);
  }
  @keyframes cta-gradient {
    0% { background-position: 100% 0; }
    50% { background-position: 0% 0; }
    100% { background-position: 100% 0; }
  }

  .btn-cta::after {
    content: "";
    position: absolute; inset: -40% -20% auto auto;
    width: 60%; height: 200%;
    background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,.36) 45%, rgba(255,255,255,.7) 50%, rgba(255,255,255,.36) 55%, transparent 100%);
    filter: blur(2px);
    pointer-events: none;
    mix-blend-mode: screen;
    animation: cta-shine 4.8s ease-in-out infinite;
  }
  .btn-cta:hover { transform: translateY(-1px) scale(1.035); box-shadow: 0 10px 26px rgba(59, 130, 246, .35); }
  .btn-cta:hover::after { animation-duration: 2.2s; }
  .btn-cta:active { transform: translateY(0) scale(1.01); box-shadow: 0 6px 18px rgba(59,130,246,.3); }
  @keyframes cta-shine {
    0%   { transform: translateX(-160%) rotate(20deg); opacity:.0; }
    10%  { opacity:.85; }
    50%  { transform: translateX(0%) rotate(20deg); opacity:.6; }
    90%  { opacity:.85; }
    100% { transform: translateX(220%) rotate(20deg); opacity:.0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .btn-cta { animation: none; }
    .btn-cta::after { animation: none; display: none; }
  }

  @media (max-width: 640px) {
    .pill {
      gap: .5rem;
      padding: .45rem .7rem;
      margin-bottom: 12px;
      max-width: min(100%, 320px);
    }

    .pill__text {
      font-size: clamp(.78rem, 3vw, .92rem);
      line-height: 1.15;
      white-space: nowrap;
    }

    .pill__cta {
      width: 30px;
      height: 30px;
      flex: 0 0 30px;
      font-size: 1rem;
    }

    .hero__actions {
      flex-direction: column;
      gap: .55rem;
      align-items: center;
      margin-inline: auto;
    }

    .hero__actions .btn-cta {
      width: auto;
      min-width: 180px;
      padding-inline: 1rem;
    }

    .status {
      justify-content: center;
      font-size: .9rem;
      text-align: center;
    }
  }

  .status { display:flex; align-items:center; gap:.5rem; color: var(--color-text-muted, #6b7280); }
  .dot {
    width:10px; height:10px; border-radius:999px; display:inline-block;
    background: radial-gradient(circle at 30% 30%, #22c55e, #16a34a);
    box-shadow: 0 0 10px rgba(34,197,94,.6);
  }

  .carousel {
    position: relative;
    width: 100vw;
    max-width: none;
    margin-top: 12px;
    left: 50%; transform: translateX(-50%);
    overflow: hidden;
  }
  .carousel__track {
    display: flex;
    gap: 18px;
    will-change: transform;
    transform: translate3d(0,0,0);
    scroll-behavior: auto !important;
  }

  .carousel__item {
    flex: 0 0 clamp(320px, 30vw, 520px);
    aspect-ratio: 16 / 10;
    border-radius: var(--radius-lg);
    position: relative;
    border: 1px solid color-mix(in oklab, var(--color-primary) 26%, transparent);
    overflow: hidden;
  }
  .carousel__item img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transform: translateZ(0);
  }
</style>






