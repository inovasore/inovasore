---
import { faqs } from "../data/faqs";
---

<section class="faq" id="faq">
  <div class="faq__halo" aria-hidden="true"></div>

  <div class="section-inner section-inner--center faq__inner">
    <span
      class="section-tag faq__tag reveal"
      style="--reveal-delay:.04s;--reveal-duration:.45s;--reveal-distance:10px"
    >
      Preguntas frecuentes
    </span>

    <h2
      class="faq__title reveal"
      style="--reveal-delay:.12s;--reveal-duration:.55s;--reveal-distance:12px"
    >
      Resolvemos tus <span class="highlight">dudas antes de empezar</span>
    </h2>

    <p
      class="faq__subtitle reveal"
      style="--reveal-delay:.2s;--reveal-duration:.45s;--reveal-distance:10px"
    >
      Respuestas claras sobre nuestros servicios, procesos y soporte para que tomes decisiones con confianza.
    </p>

    <div class="faq__grid">
      {faqs.map((item, index) => (
        <article
          class="faq__item reveal"
          data-faq
          style={`--reveal-delay:${(0.16 + index * 0.06).toFixed(2)}s;--reveal-duration:.45s;--reveal-distance:12px`}
        >
          <button class="faq__question" type="button" aria-expanded="false">
            <span>{item.question}</span>
            <span class="material-symbols-rounded faq__icon" aria-hidden="true">add</span>
          </button>
          <div class="faq__answer" hidden>
            <p>{item.answer}</p>
          </div>
        </article>
      ))}
    </div>

    <div
      class="faq__cta reveal"
      style="--reveal-delay:.32s;--reveal-duration:.45s;--reveal-distance:12px"
    >
      <div class="faq__cta-text">
        <span class="material-symbols-rounded" aria-hidden="true">help</span>
        &iquest;A&uacute;n tienes preguntas?
      </div>
      <a class="faq__cta-button" href="/contacto">Hablemos de tu proyecto</a>
    </div>
  </div>

  <script is:inline>
    (() => {
      if (typeof window === 'undefined') return;

      const items = Array.from(document.querySelectorAll('[data-faq]'));
      if (!items.length) return;

      const setIcon = (item, open) => {
        const icon = item.querySelector('.faq__icon');
        if (icon) icon.textContent = open ? 'remove' : 'add';
      };

      const closeItem = (item) => {
        item.classList.remove('faq__item--open');
        const button = item.querySelector('.faq__question');
        const panel = item.querySelector('.faq__answer');
        button?.setAttribute('aria-expanded', 'false');
        panel?.setAttribute('hidden', '');
        setIcon(item, false);
      };

      const openItem = (item) => {
        item.classList.add('faq__item--open');
        const button = item.querySelector('.faq__question');
        const panel = item.querySelector('.faq__answer');
        button?.setAttribute('aria-expanded', 'true');
        panel?.removeAttribute('hidden');
        setIcon(item, true);
      };

      items.forEach((item) => {
        closeItem(item);
        const button = item.querySelector('.faq__question');
        if (!button) return;

        const handleToggle = (event) => {
          event.preventDefault();
          const shouldOpen = !item.classList.contains('faq__item--open');

          items.forEach((other) => {
            if (other !== item) closeItem(other);
          });

          if (shouldOpen) {
            openItem(item);
          } else {
            closeItem(item);
          }
        };

        button.addEventListener('click', handleToggle);
      });
    })();
  </script>

  <style>
    .faq {
      position: relative;
      overflow: hidden;
      isolation: isolate;
      padding: var(--section-padding-y) 0 var(--section-padding-y-tight);
      background: var(--color-bg);
      color: var(--color-text);
    }

    .faq__halo {
      position: absolute;
      inset: -30% -20% auto -20%;
      height: clamp(420px, 48vw, 520px);
      pointer-events: none;
      background:
        radial-gradient(520px 320px at 20% 35%, rgba(37, 99, 235, .22), transparent 70%),
        radial-gradient(420px 260px at 80% 40%, rgba(59, 130, 246, .18), transparent 72%);
      filter: blur(18px);
      opacity: .45;
      z-index: -1;
    }

    .dark .faq__halo {
      background:
        radial-gradient(520px 320px at 20% 35%, rgba(37, 99, 235, .35), transparent 70%),
        radial-gradient(420px 260px at 80% 40%, rgba(59, 130, 246, .28), transparent 72%);
      opacity: .65;
    }

    .faq__tag {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: .45rem;
      padding: .6rem 1.35rem;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, .35);
      background: color-mix(in oklab, var(--surface, #101828) 55%, transparent);
      color: rgba(248, 250, 252, .96);
      font-weight: 500;
      width: fit-content;
      margin: 0 auto clamp(8px, 1.6vh, 12px);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, .06);
    }

    :root:not(.dark) .faq__tag {
      background: rgba(255, 255, 255, .92);
      border-color: rgba(148, 163, 184, .32);
      color: rgba(15, 23, 42, .92);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, .9);
    }

    .faq__title {
      font-size: clamp(1.8rem, 3.2vw + .6rem, 2.6rem);
      font-weight: 600;
      line-height: 1.15;
      margin: clamp(4px, 1.8vh, 8px) auto clamp(4px, 1.8vh, 8px);
      max-width: 28ch;
    }

    .faq__title .highlight {
      background-image: linear-gradient(90deg, #26d2f8 0%, #23b2ff 35%, #0973e1 70%, #3b5bff 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .faq__subtitle {
      color: color-mix(in oklab, var(--color-text) 62%, transparent);
      font-size: clamp(1rem, .9rem + .35vw, 1.1rem);
      max-width: 60ch;
      margin: 0 auto clamp(26px, 6vh, 40px);
      font-weight: 300;
    }

    :root:not(.dark) .faq__subtitle {
      color: rgba(15, 23, 42, .64);
    }

    .faq__grid {
      display: grid;
      gap: clamp(18px, 2.8vh, 24px);
      grid-template-columns: minmax(0, 1fr);
      align-items: start;
      grid-auto-rows: minmax(0, auto);
    }

    @media (min-width: 900px) {
      .faq__grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: clamp(22px, 3vw, 28px);
      }
    }

    .faq__item {
      position: relative;
      align-self: start;
      height: auto;
      padding: .35rem;
      border-radius: clamp(16px, 1.4vw, 20px);
      border: 1px solid color-mix(in oklab, var(--color-primary) 14%, rgba(148, 163, 184, .18));
      background:
        linear-gradient(135deg, color-mix(in oklab, var(--surface, #0f172a) 84%, transparent), color-mix(in oklab, var(--surface, #0f172a) 74%, transparent));
      box-shadow:
        0 16px 32px rgba(15, 23, 42, .28),
        inset 0 1px 0 rgba(255, 255, 255, .04);
      transition: transform .25s ease, box-shadow .28s ease, border-color .28s ease, background .28s ease;
      backdrop-filter: blur(12px);
    }

    @supports not ((backdrop-filter: blur(1px))) {
      .faq__item {
        backdrop-filter: none;
      }
    }

    .faq__item::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: inherit;
      pointer-events: none;
      background:
        radial-gradient(380px 240px at 85% 18%, color-mix(in oklab, var(--color-primary) 20%, transparent), transparent 72%),
        radial-gradient(320px 220px at 15% 88%, color-mix(in oklab, var(--color-primary-dark) 14%, transparent), transparent 78%);
      opacity: .12;
      transition: opacity .28s ease;
    }

    .faq__item:hover,
    .faq__item--open {
      transform: translateY(-2px);
      border-color: color-mix(in oklab, var(--color-primary) 40%, rgba(148, 163, 184, .18));
      box-shadow:
        0 20px 44px rgba(15, 23, 42, .36),
        0 18px 48px color-mix(in oklab, var(--color-primary) 18%, transparent),
        inset 0 1px 0 rgba(255, 255, 255, .08);
    }

    .faq__item:hover::after,
    .faq__item--open::after {
      opacity: .28;
    }

    :root:not(.dark) .faq__item {
      border-color: rgba(15, 23, 42, .08);
      background: linear-gradient(135deg, rgba(255, 255, 255, .98), rgba(241, 245, 249, .96));
      box-shadow: 0 12px 28px rgba(15, 23, 42, .08);
      backdrop-filter: none;
    }

    :root:not(.dark) .faq__item::after {
      content: none;
    }

    :root:not(.dark) .faq__item:hover,
    :root:not(.dark) .faq__item--open {
      border-color: rgba(37, 99, 235, .28);
      box-shadow: 0 18px 32px rgba(37, 99, 235, .16), inset 0 1px 0 rgba(255, 255, 255, .95);
    }

    .faq__question {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.05rem;
      padding: 1.1rem 1.4rem;
      border-radius: calc(clamp(12px, 1.4vw, 16px) - .25rem);
      color: color-mix(in oklab, var(--color-text) 88%, transparent);
      font-size: clamp(1rem, .85rem + .20vw, 1.18rem);
      font-weight: 400;
      letter-spacing: .01em;
      line-height: 1.35;
      cursor: pointer;
      background: transparent;
      border: none;
      text-align: left;
      font-family: inherit;
      transition: color .22s ease;
    }

    .faq__question > span:first-child {
      flex: 1;
    }

    .faq__item:hover .faq__question,
    .faq__item--open .faq__question {
      color: color-mix(in oklab, var(--color-primary) 60%, var(--color-text));
    }

    :root:not(.dark) .faq__item:hover .faq__question,
    :root:not(.dark) .faq__item--open .faq__question {
      color: color-mix(in oklab, #2563eb 65%, #1f2937);
    }

    .faq__question:focus-visible {
      outline: 2px solid color-mix(in oklab, var(--color-primary) 60%, transparent);
      outline-offset: 6px;
      border-radius: inherit;
    }

    .faq__icon {
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2.25rem;
      height: 2.25rem;
      border-radius: 999px;
      background: color-mix(in oklab, var(--surface, #121826) 52%, transparent);
      border: 1px solid color-mix(in oklab, var(--color-primary) 24%, transparent);
      color: color-mix(in oklab, var(--color-primary) 82%, #dbeafe);
      font-size: 1.25rem;
      transition: transform .28s ease, background .28s ease, border-color .28s ease, color .28s ease;
    }

    .faq__item:hover .faq__icon,
    .faq__item--open .faq__icon {
      background: color-mix(in oklab, var(--color-primary) 22%, transparent);
      border-color: color-mix(in oklab, var(--color-primary) 48%, transparent);
      color: #f8fafc;
    }

    :root:not(.dark) .faq__icon {
      background: rgba(15, 23, 42, .08);
      border-color: rgba(37, 99, 235, .25);
      color: #2563eb;
    }

    :root:not(.dark) .faq__item:hover .faq__icon,
    :root:not(.dark) .faq__item--open .faq__icon {
      background: linear-gradient(135deg, #2563eb, #3b82f6);
      border-color: transparent;
      color: #f8fafc;
    }

    .faq__answer {
      margin: 0;
      padding: 0 1.4rem 1.25rem;
      color: color-mix(in oklab, var(--color-text) 70%, transparent);
      font-size: clamp(.92rem, .9rem + .18vw, 1.05rem);
      line-height: 1.65;
      position: relative;
      text-align: left;
    }

    .faq__answer::before {
      content: '';
      display: block;
      height: 1px;
      margin: 0 0 1rem;
      background: color-mix(in oklab, var(--color-text) 16%, transparent);
      opacity: .5;
      transition: background .28s ease, opacity .28s ease;
    }

    .faq__item--open .faq__answer::before {
      background: color-mix(in oklab, var(--color-primary) 40%, transparent);
      opacity: .85;
    }

    .faq__answer > p {
      margin: 0;
    }

    :root:not(.dark) .faq__answer {
      color: rgba(15, 23, 42, .7);
    }

    :root:not(.dark) .faq__answer::before {
      background: rgba(148, 163, 184, .35);
      opacity: 1;
    }

    :root:not(.dark) .faq__item--open .faq__answer::before {
      background: color-mix(in oklab, #2563eb 45%, rgba(148, 163, 184, .35));
    }

    .faq__cta {
      margin: clamp(28px, 6vh, 40px) auto 0;
      display: inline-flex;
      align-items: center;
      gap: .9rem;
      padding: .7rem 1rem;
      border-radius: 999px;
      background: color-mix(in oklab, var(--surface, #101828) 65%, transparent);
      border: 1px solid color-mix(in oklab, var(--color-primary) 20%, transparent);
    }

    .faq__cta-text {
      display: inline-flex;
      align-items: center;
      gap: .55rem;
      color: color-mix(in oklab, var(--color-text) 76%, transparent);
      font-size: .98rem;
    }

    .faq__cta-text .material-symbols-rounded {
      font-size: 1.1rem;
    }

    .faq__cta-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: .6rem 1.45rem;
      border-radius: 999px;
      background: linear-gradient(90deg, #2563eb 0%, #3b82f6 100%);
      color: #f8fafc;
      font-weight: 600;
      text-decoration: none;
      box-shadow: 0 16px 32px rgba(37, 99, 235, .28);
      transition: transform .2s ease, box-shadow .25s ease;
    }

    .faq__cta-button:hover {
      transform: translateY(-2px);
      box-shadow: 0 22px 44px rgba(79, 70, 229, .35);
    }

    :root:not(.dark) .faq__cta {
      background: rgba(255, 255, 255, .92);
      border-color: rgba(15, 23, 42, .08);
    }

    :root:not(.dark) .faq__cta-text {
      color: rgba(15, 23, 42, .68);
    }

    @media (max-width: 720px) {
      .faq__grid {
        grid-template-columns: 1fr;
      }

      .faq__cta {
        flex-direction: column;
        padding: .8rem 1.2rem;
        gap: .8rem;
      }

      .faq__question {
        padding: .95rem 1.1rem;
        gap: .85rem;
      }

      .faq__answer {
        padding: 0 1.1rem 1.1rem;
      }
    }
  </style>
</section>










