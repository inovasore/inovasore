---
import { faqs } from "../data/faqs";
---

<section class="faq" id="faq">
  <div class="section-inner section-inner--center faq__inner">
    <span
      class="section-tag faq__tag reveal"
      style="--reveal-delay:.04s;--reveal-duration:.45s;--reveal-distance:10px;border:1px solid #1B56FD !important"
    >
      Preguntas frecuentes
    </span>

    <h2
      class="faq__title reveal"
      style="--reveal-delay:.12s;--reveal-duration:.55s;--reveal-distance:12px"
    >
      Resolvemos tus <span class="highlight">dudas antes de empezar</span>
    </h2>

    <p
      class="faq__subtitle reveal"
      style="--reveal-delay:.2s;--reveal-duration:.45s;--reveal-distance:10px"
    >
      Respuestas claras sobre nuestros servicios, procesos y soporte para que
      tomes decisiones con confianza.
    </p>

    <div class="faq__grid">
      {
        faqs.map((item, index) => (
          <article
            class="faq__item reveal"
            data-faq
            style={`--reveal-delay:${(0.16 + index * 0.06).toFixed(2)}s;--reveal-duration:.45s;--reveal-distance:12px`}
          >
            <button class="faq__question" type="button" aria-expanded="true">
              <span>{item.question}</span>
              <span
                class="material-symbols-rounded faq__icon"
                aria-hidden="true"
              >
                add
              </span>
            </button>
            <div class="faq__answer">
              <p>{item.answer}</p>
            </div>
          </article>
        ))
      }
    </div>

    </div>
  </div>

  <script is:inline>
    (() => {
      if (typeof window === "undefined") return;

      const items = Array.from(document.querySelectorAll("[data-faq]"));
      if (!items.length) return;

      const setIcon = (item, open) => {
        const icon = item.querySelector(".faq__icon");
        if (icon) icon.textContent = open ? "remove" : "add";
      };

      const closeItem = (item) => {
        item.classList.remove("faq__item--open");
        const button = item.querySelector(".faq__question");
        const panel = item.querySelector(".faq__answer");
        button?.setAttribute("aria-expanded", "false");
        panel?.setAttribute("hidden", "");
        setIcon(item, false);
      };

      const openItem = (item) => {
        item.classList.add("faq__item--open");
        const button = item.querySelector(".faq__question");
        const panel = item.querySelector(".faq__answer");
        button?.setAttribute("aria-expanded", "true");
        panel?.removeAttribute("hidden");
        setIcon(item, true);
      };

      items.forEach((item) => {
        closeItem(item);
        const button = item.querySelector(".faq__question");
        if (!button) return;

        const handleToggle = (event) => {
          event.preventDefault();
          const shouldOpen = !item.classList.contains("faq__item--open");

          items.forEach((other) => {
            if (other !== item) closeItem(other);
          });

          if (shouldOpen) {
            openItem(item);
          } else {
            closeItem(item);
          }
        };

        button.addEventListener("click", handleToggle);
      });
    })();
  </script>

  <style>
    .faq {
      position: relative;
      overflow: hidden;
      isolation: isolate;
      padding: var(--section-padding-y) 0;
      background: var(--color-bg);
      color: var(--color-text);
    }

    .faq__title {
      font-size: clamp(1.8rem, 3.2vw + 0.6rem, 2.6rem);
      font-weight: 600;
      line-height: 1.15;
      margin: clamp(4px, 1.8vh, 8px) auto clamp(4px, 1.8vh, 8px);
      max-width: 28ch;
    }

    .faq__title .highlight {
      background-image: linear-gradient(
        90deg,
        #26d2f8 0%,
        #23b2ff 35%,
        #0973e1 70%,
        #3b5bff 100%
      );
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .faq__subtitle {
      color: color-mix(in oklab, var(--color-text) 62%, transparent);
      font-size: clamp(1rem, 0.9rem + 0.35vw, 1.1rem);
      max-width: 60ch;
      margin: 0 auto clamp(26px, 6vh, 40px);
      font-weight: 300;
    }

    .faq__grid {
      display: grid;
      gap: clamp(8px, 1.6vh, 12px);
      grid-template-columns: minmax(0, 1fr);
      align-items: start;
      grid-auto-rows: minmax(0, auto);
    }

    @media (min-width: 900px) {
      .faq__grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: clamp(10px, 2vw, 16px);
      }
    }

    .faq__item {
      position: relative;
      align-self: start;
      height: auto;
      padding: 0.25rem;
      border-radius: clamp(16px, 1.4vw, 20px);
      border-color: rgba(255, 255, 255, 0.08);
      background: linear-gradient(
        180deg,
        rgba(12, 14, 22, 0.92),
        rgba(12, 14, 22, 0.86)
      );
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
      transition:
        transform 0.25s ease,
        box-shadow 0.28s ease,
        border-color 0.28s ease,
        background 0.28s ease;
      backdrop-filter: blur(12px);
    }

    @supports not ((backdrop-filter: blur(1px))) {
      .faq__item {
        backdrop-filter: none;
      }
    }

    .faq__item::after {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: inherit;
      pointer-events: none;
      background:
        radial-gradient(
          380px 240px at 85% 18%,
          color-mix(in oklab, var(--color-primary) 20%, transparent),
          transparent 72%
        ),
        radial-gradient(
          320px 220px at 15% 88%,
          color-mix(in oklab, var(--color-primary-dark) 14%, transparent),
          transparent 78%
        );
      opacity: 0.12;
      transition: opacity 0.28s ease;
      mix-blend-mode: screen;
    }

    .faq__item:hover,
    .faq__item--open {
      transform: translateY(-2px);
      border-color: rgba(59, 130, 246, 0.35);
      box-shadow:
        0 10px 30px rgba(0, 0, 0, 0.25),
        inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }

    .faq__item:hover::after,
    .faq__item--open::after {
      opacity: 0.24;
    }

    .faq__question {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.85rem;
      padding: 0.9rem 1.15rem;
      border-radius: calc(clamp(12px, 1.4vw, 16px) - 0.25rem);
      color: color-mix(in oklab, var(--color-text) 88%, transparent);
      font-size: clamp(1rem, 0.85rem + 0.2vw, 1.18rem);
      font-weight: 400;
      letter-spacing: 0.01em;
      line-height: 1.35;
      cursor: pointer;
      background: transparent;
      border: none;
      text-align: left;
      font-family: inherit;
      transition: color 0.22s ease;
    }

    .faq__question > span:first-child {
      flex: 1;
    }

    .faq__item:hover .faq__question,
    .faq__item--open .faq__question {
      color: color-mix(in oklab, var(--color-primary) 60%, var(--color-text));
    }

    .faq__question:focus-visible {
      outline: 2px solid
        color-mix(in oklab, var(--color-primary) 60%, transparent);
      outline-offset: 6px;
      border-radius: inherit;
    }

    .faq__icon {
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2.25rem;
      height: 2.25rem;
      border-radius: 999px;
      background: var(--color-primary);
      color: #fff;
      border: none;
      box-shadow: none;
      font-size: 1.25rem;
      transition:
        transform 0.28s ease,
        background 0.28s ease,
        border-color 0.28s ease,
        color 0.28s ease;
    }

    .faq__item:hover .faq__icon,
    .faq__item--open .faq__icon {
      background: color-mix(in oklab, var(--color-primary) 22%, transparent);
      border-color: color-mix(in oklab, var(--color-primary) 48%, transparent);
      color: #f8fafc;
    }

    .faq__answer {
      margin: 0;
      padding: 0 1.2rem 1.05rem;
      color: color-mix(in oklab, var(--color-text) 70%, transparent);
      font-size: clamp(0.92rem, 0.9rem + 0.18vw, 1.05rem);
      line-height: 1.65;
      position: relative;
      text-align: left;
    }

    .faq__answer::before {
      content: "";
      display: block;
      height: 1px;
      margin: 0 0 1rem;
      background: color-mix(in oklab, var(--color-text) 16%, transparent);
      opacity: 0.5;
      transition:
        background 0.28s ease,
        opacity 0.28s ease;
    }

    .faq__item--open .faq__answer::before {
      background: color-mix(in oklab, var(--color-primary) 40%, transparent);
      opacity: 0.85;
    }

    .faq__answer > p {
      margin: 0;
    }



      .faq__question {
        padding: 0.75rem 1rem;
        gap: 0.7rem;
      }

      .faq__answer {
        padding: 0 1rem 0.9rem;
      }
    }
  </style>
</section>
