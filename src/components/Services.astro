    align-items: center;
    gap: 10px;
    width: min(75%, 260px);
    min-height: 46px;
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    padding: 6px 10px;
    border-radius: 10px;
    color: #f1f5f9;
    font-weight: 600;
    position: relative;
    z-index: 2;
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.34);
    transition:
      transform 0.45s cubic-bezier(0.2, 0.8, 0.2, 1),
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  .soc-fb {
    margin: 0 auto;
    transform: translateX(-38px);
  }

  .soc-ig {
    margin: -4px auto 0;
    z-index: 4;
  }

  .soc-tk {
    margin: -4px auto 0;
    transform: translateX(38px);
  }

  .spotlight-card:hover .soc-fb {
    transform: translate(-50px, -6px);
  }
  .spotlight-card:hover .soc-ig {
    transform: translate(0, -4px);
  }
  .spotlight-card:hover .soc-tk {
    transform: translate(50px, 5px);
  }

  .soc-icon {
    width: 34px;
    height: 34px;
    border-radius: 50%;
