---
import { featuredServices } from "../data/services";

const { offsetTop = "0px" } = Astro.props;
---

<section
  class="services"
  id="servicios"
  style={`--services-offset:${offsetTop}`}
>
  <div class="services__glow" aria-hidden="true"></div>

  <div class="section-inner section-inner--center services__inner">
    <span
      class="section-tag services__tag services__tag--compact reveal"
      style="--reveal-delay:.04s;--reveal-duration:.45s;--reveal-distance:10px;padding-inline:0.5rem;font-size:0.95rem;"
    >
      ¿Qué hacemos?
    </span>

    <h2
      class="services__title reveal"
      style="--reveal-delay:.12s;--reveal-duration:.55s;--reveal-distance:12px"
    >
      Porque Inovasore <span class="highlight">potencia tus servicios.</span>
    </h2>

    <p
      class="services__subtitle reveal"
      style="--reveal-delay:.2s;--reveal-duration:.45s;--reveal-distance:10px"
    >
      Nuestro equipo combina estrategia, diseño y desarrollo para construir
      experiencias digitales a medida.
    </p>

    <div class="services__spotlight">
      {
        featuredServices.map((service, index) => {
          const cardClass = ["spotlight-card", "reveal"]
            .filter(Boolean)
            .join(" ");
          const style = `--reveal-delay:${(0.16 + index * 0.08).toFixed(2)}s;--reveal-duration:.45s;--reveal-distance:12px`;
          return (
            <article class={cardClass} style={style}>
              <a
                href="/servicios"
                class="spotlight-card__link"
                aria-label={`Ver más sobre ${service.title}`}
              >
                <span class="spotlight-card__link-text">Ver más</span>
                <img
                  src="/arrow.svg"
                  alt=""
                  class="spotlight-card__arrow"
                  aria-hidden="true"
                />
              </a>
              <div class="spotlight-card__icon" aria-hidden="true">
                <span class="material-symbols-rounded" aria-hidden="true">
                  {service.icon}
                </span>
              </div>
              <div class="spotlight-card__body">
                <h3 class="spotlight-card__title">{service.title}</h3>
                <p class="spotlight-card__desc">{service.description}</p>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>

  <div class="scroll-reveal-container">
    <p class="scroll-reveal-text">
      <span class="scroll-line" data-line="1"
        >¡AUMENTA TU PRESENCIA ONLINE Y</span
      >
      <span class="scroll-line" data-line="2"
        >CONÉCTATE CON LO QUE REALMENTE</span
      >
      <span class="scroll-line" data-line="3">IMPORTA PARA TU NEGOCIO!</span>
    </p>
  </div>
</section>

<script>
  function initScrollReveal() {
    const lines = document.querySelectorAll(
      ".scroll-line",
    ) as NodeListOf<HTMLElement>;
    if (!lines.length) return;

    const updateScroll = () => {
      const container = document.querySelector(".scroll-reveal-container");
      if (!container) return;

      const rect = container.getBoundingClientRect();
      const windowHeight = window.innerHeight;

      // Calcular progreso general (0 a 1)
      const start = windowHeight * 0.85;
      const end = windowHeight * 0.25;

      let overallProgress = 0;
      if (rect.top < start) {
        overallProgress = 1 - (rect.top - end) / (start - end);
      }
      overallProgress = Math.min(Math.max(overallProgress, 0), 1);

      // Dividir el progreso entre las 3 líneas
      // Línea 1: 0% - 33%, Línea 2: 33% - 66%, Línea 3: 66% - 100%
      lines.forEach((line, index) => {
        const lineStart = index / lines.length;
        const lineEnd = (index + 1) / lines.length;

        let lineProgress = 0;
        if (overallProgress > lineStart) {
          lineProgress = (overallProgress - lineStart) / (lineEnd - lineStart);
        }
        lineProgress = Math.min(Math.max(lineProgress, 0), 1);

        line.style.setProperty("--line-progress", `${lineProgress * 100}%`);
      });
    };

    window.addEventListener("scroll", updateScroll, { passive: true });
    updateScroll();
  }

  document.addEventListener("astro:page-load", initScrollReveal);
  initScrollReveal();
</script>

<style>
  .services {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    margin: 0;
    padding: calc(var(--section-padding-y) * 1.35) 0 var(--section-padding-y);
    background: transparent;
    color: var(--color-text);
    scroll-margin-top: var(--services-offset, clamp(72px, 14vw, 120px));
  }

  .services__glow {
    display: none;
  }

  .services__inner {
    display: grid;
    row-gap: clamp(2px, 1.2vh, 10px);
    text-align: center;
    max-width: 1080px;
  }

  @media (max-width: 720px) {
    .services {
      margin-top: clamp(12px, 4vh, 26px);
    }

    .services__tag {
      margin: 0 auto;
    }
  }

  .services__title {
    font-size: clamp(1.8rem, 3.1vw + 0.6rem, 2.5rem);
    font-weight: 600;
    line-height: 1.13;
    margin: clamp(6px, 1.2vh, 10px) auto clamp(4px, 1vh, 8px);
    max-width: 26ch;
  }

  .services__subtitle {
    color: color-mix(in oklab, var(--color-text) 50%, transparent);
    font-size: clamp(1rem, 0.9rem + 0.25vw, 1.1rem);
    margin: 0 auto clamp(12px, 2.6vh, 18px);
    max-width: 60ch;
    font-weight: 300;
  }

  .services__tag--compact {
    padding-inline: 0.85rem !important;
    font-size: clamp(0.9rem, 0.85rem + 0.2vw, 1rem) !important;
    display: inline-flex !important;
    width: fit-content !important;
    margin-inline: auto !important;
  }

  .services__title .highlight {
    display: inline-block;
    background-image: linear-gradient(
      90deg,
      #26d2f8 0%,
      #23b2ff 35%,
      #0973e1 70%,
      #3b5bff 100%
    );
    background-size: 100% 100%;
    background-repeat: no-repeat;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }

  .services__spotlight {
    display: grid;
    gap: clamp(18px, 2.6vw, 32px);
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    margin-top: clamp(4px, 1.2vw, 12px);
  }

  @media (min-width: 768px) {
    .services__spotlight {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .spotlight-card {
    position: relative;
    text-align: left;
    padding: 20px 22px;
    border-radius: 18px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: linear-gradient(
      180deg,
      rgba(12, 14, 22, 0.92),
      rgba(12, 14, 22, 0.86)
    );
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
    transition:
      transform 0.18s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease;
  }

  .spotlight-card__link {
    position: absolute;
    top: 20px;
    right: 22px;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 16px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 50px;
    background: transparent;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
    font-weight: 400;
    z-index: 3;
    transition: all 0.25s ease;
    backdrop-filter: blur(4px);
  }

  .spotlight-card__link:hover {
    background: transparent;
    border-color: rgba(59, 130, 246, 0.6);
    color: #fff;
    transform: translateX(2px);
  }

  .spotlight-card__link:active {
    background: rgba(59, 130, 246, 0.2);
    border-color: rgba(59, 130, 246, 0.4);
  }

  .spotlight-card__link-text {
    font-size: 0.9rem;
  }

  .spotlight-card__arrow {
    width: 14px;
    height: 14px;
    transition: transform 0.25s ease;
  }

  .spotlight-card__link:hover .spotlight-card__arrow {
    transform: translate(2px, -2px);
  }

  .spotlight-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 18px;
    height: 4px;
    width: 76px;
    border-radius: 0 0 8px 8px;
    pointer-events: none;
    z-index: 2;
    background: linear-gradient(90deg, #0973e1 0%, #0446ba 100%);
    box-shadow: 0 8px 18px rgba(9, 115, 225, 0.35);
    opacity: 0.95;
  }

  .spotlight-card::after {
    content: "";
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    pointer-events: none;
    z-index: 1;
    background:
      radial-gradient(
        420px 260px at 110% 120%,
        rgba(9, 115, 225, 0.12),
        transparent 60%
      ),
      radial-gradient(
        300px 220px at -8% 12%,
        rgba(9, 115, 225, 0.06),
        transparent 72%
      );
    mix-blend-mode: screen;
    opacity: 0.24;
    transition: opacity 0.25s ease;
  }

  .spotlight-card:hover {
    transform: translateY(-2px);
    border-color: rgba(59, 130, 246, 0.35);
    box-shadow:
      0 10px 30px rgba(0, 0, 0, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    filter: saturate(112%) brightness(1.02);
  }

  .spotlight-card__icon {
    position: relative;
    width: 44px;
    height: 45px;
    border-radius: 10px;
    display: grid;
    place-items: center;
    font-size: 20px;
    margin-bottom: 8px;
    background: var(--color-primary);
    color: #fff;
    border: none;
    box-shadow: none;
  }

  .spotlight-card__body {
    display: grid;
    gap: 0.45rem;
    position: relative;
    z-index: 1;
  }

  .spotlight-card__title {
    font-size: 1.15rem;
    font-weight: 600;
    color: #fff;
  }

  .spotlight-card__desc {
    color: #d6e0ef;
    font-size: 0.98rem;
    margin-top: 0.35rem;
    font-weight: 300;
    line-height: 1.4;
  }

  .scroll-reveal-container {
    margin-top: clamp(60px, 12vh, 100px);
    margin-bottom: clamp(40px, 8vh, 60px);
    width: 100%;
    display: flex;
    justify-content: center;
    padding: 0 clamp(20px, 4vw, 40px);
  }

  .scroll-reveal-text {
    font-size: clamp(1.4rem, 0.8rem + 2.2vw, 2.8rem); /* Tamaño reducido */
    line-height: 1.3; /* Interlineado más amplio */
    font-weight: 700;
    text-align: center;
    max-width: 100%;
    margin: 0;
    text-transform: uppercase;
    display: flex;
    flex-direction: column;
    gap: 0.1em;
  }

  .scroll-line {
    display: block;
    --line-progress: 0%;
    background: linear-gradient(
      to right,
      #ffffff 0%,
      #ffffff var(--line-progress),
      rgba(255, 255, 255, 0.15) var(--line-progress),
      rgba(255, 255, 255, 0.15) 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
</style>
