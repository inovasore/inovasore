<script>
  let spotlightActive = false;
  let scrollRevealCleanup: (() => void) | null = null;

  function initCardSpotlight() {
    if (spotlightActive) return;
    spotlightActive = true;

    const cleanups: (() => void)[] = [];

    document
      .querySelectorAll<HTMLElement>(".spotlight-card")
      .forEach((card) => {
        let rafPending = false;
        let cx = 0,
          cy = 0;

        const update = () => {
          card.style.setProperty("--mouse-x", `${cx}px`);
          card.style.setProperty("--mouse-y", `${cy}px`);
          rafPending = false;
        };

        const onMove = (e: MouseEvent) => {
          const rect = card.getBoundingClientRect();
          cx = e.clientX - rect.left;
          cy = e.clientY - rect.top;
          if (!rafPending) {
            rafPending = true;
            requestAnimationFrame(update);
          }
        };

        card.addEventListener("mousemove", onMove);
        cleanups.push(() => card.removeEventListener("mousemove", onMove));
      });

    document.addEventListener(
      "astro:before-swap",
      () => {
        cleanups.forEach((fn) => fn());
        spotlightActive = false;
      },
      { once: true },
    );
  }

  function initScrollReveal() {
    if (scrollRevealCleanup) return;

    const lines = document.querySelectorAll(
      ".scroll-line",
    ) as NodeListOf<HTMLElement>;
    if (!lines.length) return;

    const updateScroll = () => {
      const container = document.querySelector(".scroll-reveal-container");
      if (!container) return;

      const rect = container.getBoundingClientRect();
      const windowHeight = window.innerHeight;
      const start = windowHeight * 0.85;
      const end = windowHeight * 0.25;

      let overallProgress = 0;
      if (rect.top < start) {
        overallProgress = 1 - (rect.top - end) / (start - end);
      }
      overallProgress = Math.min(Math.max(overallProgress, 0), 1);

      lines.forEach((line, index) => {
        const lineStart = index / lines.length;
        const lineEnd = (index + 1) / lines.length;
        let lineProgress = 0;
        if (overallProgress > lineStart) {
          lineProgress = (overallProgress - lineStart) / (lineEnd - lineStart);
        }
        line.style.setProperty(
          "--line-progress",
          `${Math.min(Math.max(lineProgress, 0), 1) * 100}%`,
        );
      });
    };

    window.addEventListener("scroll", updateScroll, { passive: true });
    updateScroll();

    scrollRevealCleanup = () => {
      window.removeEventListener("scroll", updateScroll);
      scrollRevealCleanup = null;
    };
    document.addEventListener("astro:before-swap", scrollRevealCleanup, {
      once: true,
    });
  }

  document.addEventListener("astro:page-load", () => {
    initCardSpotlight();
    initScrollReveal();
  });
  initCardSpotlight();
  initScrollReveal();
</script>

<style>
  .services {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    margin: 0;
    padding: calc(var(--section-padding-y) * 0.9) 0 var(--section-padding-y);
    background: transparent;
    color: var(--color-text);
    scroll-margin-top: var(--services-offset, clamp(72px, 14vw, 120px));
  }

  .services__inner {
    display: grid;
    row-gap: 0;
    text-align: center;
    max-width: 1200px;
  }

  @media (max-width: 720px) {
    .services {
      margin-top: clamp(8px, 2vh, 16px);
      padding-top: calc(var(--section-padding-y) * 0.7);
    }

    .services__tag {
      margin: 0 auto;
    }
  }

  .services__title {
    font-size: clamp(1.8rem, 3.1vw + 0.6rem, 2.5rem);
    font-weight: 600;
    line-height: 1.13;
    margin: clamp(6px, 1.2vh, 10px) auto clamp(4px, 1vh, 8px);
    max-width: 26ch;
  }

  .services__subtitle {
    color: color-mix(in oklab, var(--color-text) 60%, transparent);
    font-size: clamp(1rem, 0.9rem + 0.25vw, 1.1rem);
    margin: 0 auto clamp(32px, 5vh, 48px);
    max-width: 60ch;
    font-weight: 300;
  }

  .services__tag--compact {
    padding-inline: 0.85rem !important;
    font-size: clamp(0.9rem, 0.85rem + 0.2vw, 1rem) !important;
    display: inline-flex !important;
    width: fit-content !important;
    margin-inline: auto !important;
  }

  .services__title .highlight {
    display: inline-block;
    background-image: linear-gradient(
      90deg,
      #26d2f8 0%,
      #23b2ff 35%,
      #0973e1 70%,
      #3b5bff 60%
    );
    background-size: 100% 100%;
    background-repeat: no-repeat;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }


  /* ── Classic Service Cards (mismo estilo que WhyUs) ── */
  .services-classic-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(18px, 2.6vw, 26px);
    margin-top: clamp(28px, 6vh, 44px);
    max-width: 1200px;
    margin-inline: auto;
  }

  .classic-card {
    position: relative;
    text-align: left;
    padding: 28px 28px 24px;
    border-radius: 18px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: linear-gradient(
      180deg,
      rgba(12, 14, 22, 0.92),
      rgba(12, 14, 22, 0.86)
    );
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
    transition:
      transform 0.18s ease,
      box-shadow 0.25s ease,
      border-color 0.25s ease;
  }

  /* Barra azul superior — igual a WhyUs */
  .classic-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 18px;
    height: 4px;
    width: 76px;
    border-radius: 0 0 8px 8px;
    pointer-events: none;
    z-index: 2;
    background: linear-gradient(90deg, #0973e1 0%, #0446ba 100%);
    box-shadow: 0 8px 18px rgba(9, 115, 225, 0.35);
    opacity: 0.95;
  }

  /* Halo radial — igual a WhyUs */
  .classic-card::after {
    content: "";
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    pointer-events: none;
    z-index: 1;
    background:
      radial-gradient(
        420px 260px at 110% 120%,
        rgba(9, 115, 225, 0.12),
        transparent 60%
      ),
      radial-gradient(
        300px 220px at -8% 12%,
        rgba(9, 115, 225, 0.06),
        transparent 72%
      );
    mix-blend-mode: screen;
    opacity: 0.24;
    transition: opacity 0.25s ease;
  }

  .classic-card:hover {
    transform: translateY(-2px);
    border-color: rgba(59, 130, 246, 0.35);
    box-shadow:
      0 10px 30px rgba(0, 0, 0, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
    filter: saturate(112%) brightness(1.02);
  }

  .classic-card:hover::after {
    opacity: 0.3;
  }

  /* Ocultar top-bar (ya lo hace ::before) */
  .classic-card__top-bar {
    display: none;
  }

  /* Fila superior: ícono + botón */
  .classic-card__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  /* Botón "Ver más" */
  .classic-card__btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 18px;
    border-radius: 99px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.88rem;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
    white-space: nowrap;
  }

  .classic-card__btn:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.3);
    color: #fff;
  }

  .classic-card__btn .material-symbols-rounded {
    font-size: 16px;
  }

  /* Ícono — copia exacta de .why__icon */
  .classic-card__icon-box {
    position: relative;
    width: 45px;
    height: 45px;
    border-radius: 10px;
    display: grid;
    place-items: center;
    font-size: 20px;
    margin-bottom: 8px;
    background: var(--color-primary);
    color: #fff;
    border: none;
    box-shadow: none;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .classic-card__icon-box .material-symbols-rounded {
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .classic-card:hover .classic-card__icon-box {
    transform: scale(1.1);
  }

  /* Animaciones por posición — igual a WhyUs */
  .classic-card:nth-child(1):hover .classic-card__icon-box .material-symbols-rounded,
  .classic-card:nth-child(4):hover .classic-card__icon-box .material-symbols-rounded {
    animation: cc-bounce-rotate 0.6s ease;
  }

  .classic-card:nth-child(2):hover .classic-card__icon-box .material-symbols-rounded,
  .classic-card:nth-child(5):hover .classic-card__icon-box .material-symbols-rounded {
    animation: cc-pulse-scale 0.5s ease;
  }

  .classic-card:nth-child(3):hover .classic-card__icon-box .material-symbols-rounded,
  .classic-card:nth-child(6):hover .classic-card__icon-box .material-symbols-rounded {
    animation: cc-shake 0.5s ease;
  }

  @keyframes cc-bounce-rotate {
    0%, 100% { transform: rotate(0deg) scale(1); }
    25%       { transform: rotate(-10deg) scale(1.15); }
    75%       { transform: rotate(10deg) scale(1.15); }
  }

  @keyframes cc-pulse-scale {
    0%, 100% { transform: scale(1); }
    50%       { transform: scale(1.25); }
  }

  @keyframes cc-shake {
    0%, 100% { transform: translateX(0); }
    25%       { transform: translateX(-4px) rotate(-5deg); }
    75%       { transform: translateX(4px) rotate(5deg); }
  }

  /* Contenido — copia de .why__card-title y .why__card-desc */
  .classic-card__header {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .classic-card__content {
    display: contents;
  }

  .classic-card__title {
    font-size: 1.15rem;
    font-weight: 600;
    color: #fff;
    margin: 0 0 0 0;
  }

  .classic-card__desc {
    color: color-mix(in oklab, var(--color-text) 62%, transparent);
    font-size: 0.98rem;
    margin-top: 0.35rem;
    font-weight: 300;
    line-height: 1.4;
    margin-bottom: 0;
  }

  @media (max-width: 640px) {
    .services-classic-grid {
      grid-template-columns: 1fr;
    }
  }


  .spotlight-card {
    --card-radius: 24px;
    background: linear-gradient(
      180deg,
      rgba(12, 14, 22, 0.92),
      rgba(12, 14, 22, 0.86)
    );
    border-radius: var(--card-radius);
    padding: clamp(16px, 2vw, 22px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    min-height: clamp(240px, 20vw, 290px);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
    transition:
      transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.4s ease,
      border-color 0.4s ease;
  }

  .spotlight-card--web,
  .spotlight-card--auto {
    min-height: clamp(260px, 22vw, 310px);
  }

  .spotlight-card:hover {
    transform: translateY(-2px);
    border-color: rgba(59, 130, 246, 0.35);
    box-shadow:
      0 10px 30px rgba(0, 0, 0, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }

  .spotlight-card::before,
  .spotlight-card::after {
    content: "";
    position: absolute;
    border-radius: inherit;
    pointer-events: none;
  }

  .spotlight-card::before {
    inset: 0;
    z-index: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
    opacity: 0.035;
    mix-blend-mode: overlay;
  }

  .spotlight-card::after {
    inset: 0;
    z-index: 0;
    background: radial-gradient(
      600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
      rgba(27, 86, 253, 0.08),
      transparent 40%
    );
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .spotlight-card:hover::after {
    opacity: 1;
  }

  .spotlight-card__header {
    position: relative;
    z-index: 2;
    margin-bottom: clamp(12px, 1.6vw, 18px);
    text-align: left;
  }

  .spotlight-card__title {
    font-size: clamp(1.3rem, 1.5vw + 1rem, 1.6rem);
    font-weight: 700;
    color: #f8fafc;
    margin: 0 0 8px 0;
    letter-spacing: 0;
  }

  .spotlight-card__desc {
    color: color-mix(in oklab, var(--color-text) 60%, transparent);
    font-size: 0.98rem;
    line-height: 1.4;
    font-weight: 300;
    margin: 0;
    max-width: 36rem;
  }

  .spotlight-card__ill {
    flex: 1;
    position: relative;
    display: flex;
    z-index: 2;
    min-height: 174px;
  }

  /* Social */
  .svc-ill--social {
    flex-direction: column;
    align-items: stretch;
    justify-content: flex-start;
    min-height: 160px;
    padding: 28px 0 0;
  }

  .soc-orbit {
    position: absolute;
    inset: auto 8% 8% 8%;
    height: 78%;
    border-radius: 999px;
    background:
      radial-gradient(
        circle at 45% 50%,
        rgba(91, 124, 255, 0.28),
        transparent 46%
      ),
      radial-gradient(
        circle at 58% 42%,
        rgba(38, 210, 248, 0.16),
        transparent 38%
      );
    filter: blur(24px);
    opacity: 0.75;
  }

  .soc-pill {
