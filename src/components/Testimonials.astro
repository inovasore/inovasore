---
import { testimonials } from "../data/testimonials";
---

<section class="testimonials">
    <div class="testimonials__inner">
        <span
            class="section-tag testimonials__tag reveal"
            style="--reveal-delay:.04s;--reveal-duration:.45s;--reveal-distance:10px"
        >
            Testimonios Reales
        </span>

        <h2
            class="testimonials__title reveal"
            style="--reveal-delay:.12s;--reveal-duration:.55s;--reveal-distance:12px"
        >
            Lo que nuestros clientes <span class="highlight"
                >dicen de nosotros</span
            >
        </h2>

        <p
            class="testimonials__subtitle reveal"
            style="--reveal-delay:.2s;--reveal-duration:.45s;--reveal-distance:10px"
        >
            Súmate a las nueva era tecnológica. ellos confiaron en Inovasore y
            transformaron sus resultados.
        </p>

        <div class="testimonials__carousel-wrapper">
            <div class="testimonials__carousel" id="testimonialsCarousel">
                {
                    testimonials.map((testimonial) => (
                        <div class="testimonial-card">
                            <div class="testimonial-card__stars">
                                {[...Array(testimonial.rating)].map(() => (
                                    <span class="star">★</span>
                                ))}
                            </div>
                            <p class="testimonial-card__text">
                                {testimonial.testimonial}
                            </p>
                            <div class="testimonial-card__author">
                                <img
                                    src={testimonial.avatar}
                                    alt={testimonial.name}
                                    class="testimonial-card__avatar"
                                    width="48"
                                    height="48"
                                />
                                <span class="testimonial-card__name">
                                    {testimonial.name}
                                </span>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</section>

<script>
    function initTestimonials() {
        const carousel = document.getElementById("testimonialsCarousel");
        if (!carousel) return;

        const cards = carousel.querySelectorAll(".testimonial-card");
        let currentIndex = 0;
        let intervalId: number | null = null;

        function updateCarousel(smooth = true) {
            const isMobile = window.innerWidth <= 768;
            const isTablet = window.innerWidth <= 1024 && window.innerWidth > 768;
            const cardsToShow = isMobile ? 1 : isTablet ? 2 : 3;
            const firstCard = cards[0] as HTMLElement;
            const cardWidth = firstCard?.offsetWidth || 0;
            const gap = isMobile ? 20 : 32;
            const offset = currentIndex * (cardWidth + gap);

            if (smooth) {
                carousel.style.transition = "transform 0.6s ease-in-out";
            } else {
                carousel.style.transition = "none";
            }

            carousel.style.transform = `translateX(-${offset}px)`;
        }

        function nextSlide() {
            const isMobile = window.innerWidth <= 768;
            const isTablet = window.innerWidth <= 1024 && window.innerWidth > 768;
            const cardsToShow = isMobile ? 1 : isTablet ? 2 : 3;

            currentIndex++;

            // Si llegamos al final, avanzamos uno más para el efecto
            if (currentIndex >= cards.length - cardsToShow + 1) {
                updateCarousel(true);

                // Después de la transición, volvemos al inicio sin animación
                setTimeout(() => {
                    currentIndex = 0;
                    updateCarousel(false);
                }, 600);
            } else {
                updateCarousel(true);
            }
        }

        function startAutoSlide() {
            if (intervalId) clearInterval(intervalId);
            intervalId = window.setInterval(nextSlide, 4000);
        }

        function handleResize() {
            currentIndex = 0;
            updateCarousel(false);
            startAutoSlide();
        }

        window.addEventListener("resize", handleResize);
        updateCarousel(false);
        startAutoSlide();

        // Cleanup
        return () => {
            if (intervalId) clearInterval(intervalId);
            window.removeEventListener("resize", handleResize);
        };
    }

    document.addEventListener("astro:page-load", initTestimonials);
    initTestimonials();
</script>

<style>
    .testimonials {
        position: relative;
        padding: clamp(32px, 6vh, 56px) 0;
        background: var(--color-bg);
        color: var(--color-text);
        overflow: hidden;
    }

    .testimonials__inner {
        width: clamp(280px, 92vw, 1200px);
        margin: 0 auto;
        padding: 0;
        text-align: center;
    }

    .testimon__tag {
        display: inline-block;
        margin-bottom: clamp(12px, 2vh, 16px);
    }

    .testimonials__title {
        font-size: clamp(1.8rem, 3.1vw + 0.6rem, 2.5rem);
        font-weight: 600;
        line-height: 1.13;
        margin: clamp(6px, 1.2vh, 10px) auto clamp(4px, 1vh, 8px);
        max-width: 26ch;
    }

    .testimonials__title .highlight {
        display: inline-block;
        background-image: linear-gradient(
            90deg,
            #26d2f8 0%,
            #23b2ff 35%,
            #0973e1 70%,
            #3b5bff 100%
        );
        background-size: 100% 100%;
        background-repeat: no-repeat;
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        -webkit-text-fill-color: transparent;
    }

    .testimonials__subtitle {
        color: color-mix(in oklab, var(--color-text) 50%, transparent);
        font-size: clamp(1rem, 0.9rem + 0.25vw, 1.1rem);
        margin: 0 auto clamp(32px, 5vh, 48px);
        max-width: 60ch;
        font-weight: 300;
    }

    .testimonials__carousel-wrapper {
        position: relative;
        width: 100%;
        margin: 0 auto;
        overflow: hidden;
    }

    .testimonials__carousel {
        display: flex;
        gap: 32px;
        transition: transform 0.6s ease-in-out;
    }

    .testimonial-card {
        flex: 0 0 calc(33.333% - 21.333px);
        background: linear-gradient(
            180deg,
            rgba(12, 14, 22, 0.92),
            rgba(12, 14, 22, 0.86)
        );
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 18px;
        padding: clamp(24px, 4vw, 32px);
        text-align: left;
        display: flex;
        flex-direction: column;
        gap: 20px;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
        transition: 
            transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275),
            border-color 0.3s ease,
            box-shadow 0.3s ease;
    }

    .testimonial-card:hover {
        transform: translateY(-8px) scale(1.02);
        border-color: rgba(59, 130, 246, 0.3);
        box-shadow: 
            0 20px 40px rgba(0, 0, 0, 0.4),
            inset 0 1px 0 rgba(255, 255, 255, 0.05);
    }

    .testimonial-card__stars {
        display: flex;
        gap: 4px;
    }

    .star {
        color: #ffc107;
        font-size: 20px;
    }

    .testimonial-card__text {
        color: #d6e0ef;
        font-size: clamp(0.95rem, 0.9rem + 0.2vw, 1.05rem);
        line-height: 1.6;
        margin: 0;
        font-weight: 300;
        flex: 1;
    }

    .testimonial-card__author {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .testimonial-card__avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        object-fit: cover;
    }

    .testimonial-card__name {
        color: #fff;
        font-size: 1rem;
        font-weight: 500;
    }

    @media (max-width: 1024px) {
        .testimonial-card {
            flex: 0 0 calc(50% - 16px);
        }
    }

    @media (max-width: 768px) {
        .testimonial-card {
            flex: 0 0 100%;
        }

        .testimonials__carousel {
            gap: 20px;
        }
    }
    @media (max-width: 840px) {
        .testimonial-card:hover {
            transform: none !important;
        }
    }
</style>
