---
import { projects } from "../data/projects";
---

<section class="projects" id="proyectos">
  <div class="projects__halo" aria-hidden="true"></div>
  <div class="projects__inner">
    <span
      class="section-tag projects__tag reveal"
      style="--reveal-delay:.06s;--reveal-duration:.45s;--reveal-distance:10px"
    >
      Proyectos
    </span>
    <h2
      class="projects__title reveal"
      style="--reveal-delay:.14s;--reveal-duration:.55s;--reveal-distance:14px"
    >
      Explora nuestros <span class="highlight">proyectos recientes</span>
    </h2>
    <p
      class="projects__subtitle reveal"
      style="--reveal-delay:.22s;--reveal-duration:.45s;--reveal-distance:10px"
    >
      Diseñamos experiencias digitales para marcas y startups, combinando estrategia, diseño y tecnología.
    </p>

    <div class="projects__grid">
      {projects.map((project, index) => (
        <article
          class="project-card reveal"
          style={`--reveal-delay:${(0.16 + index * 0.08).toFixed(2)}s;--reveal-duration:.45s;--reveal-distance:12px`}
        >
          <figure class="project-card__media">
            <img src={project.image} alt={project.title} loading="lazy" decoding="async" />
          </figure>
          <div class="project-card__body">
            <div class="project-card__heading">
              <h3>{project.title}</h3>
              <span class="project-card__pill">{project.category}</span>
            </div>
            <p class="project-card__description">{project.description}</p>
            <a class="project-card__link" href={project.url}>
              Solicita un proyecto similar
              <span class="material-symbols-rounded" aria-hidden="true">arrow_outward</span>
            </a>
          </div>
        </article>
      ))}
    </div>

    <div class="projects__cta">
      <a class="projects__button" href="/contacto">
        Solicita el portafolio completo
        <span class="material-symbols-rounded" aria-hidden="true">trending_flat</span>
      </a>
    </div>
  </div>

  <style>
    .projects {
      position: relative;
      padding: var(--section-padding-y) 0 var(--section-padding-y-tight);
      background: var(--color-bg);
      color: var(--color-text);
      overflow: hidden;
      isolation: isolate;
      margin: var(--section-padding-y) 0 var(--section-padding-y-tight);
      padding: var(--section-padding-y) 0 var(--section-padding-y-tight);
    }

    .dark .projects {
      background:
        radial-gradient(circle at top, rgba(40, 63, 255, .24), transparent 55%),
        linear-gradient(180deg, #050613 0%, #03020d 45%, #020107 100%);
    }

    .projects__halo {
      position: absolute;
      inset: -40% -20% auto -20%;
      height: 420px;
      pointer-events: none;
      background:
        radial-gradient(520px 320px at 20% 40%, rgba(99, 102, 241, .28), transparent 70%),
        radial-gradient(420px 280px at 80% 45%, rgba(56, 189, 248, .26), transparent 72%);
      filter: blur(18px);
      opacity: .45;
      z-index: -1;
    }

    .dark .projects__halo {
      background:
        radial-gradient(520px 320px at 20% 40%, rgba(99, 102, 241, .45), transparent 70%),
        radial-gradient(420px 280px at 80% 45%, rgba(56, 189, 248, .35), transparent 72%);
      opacity: .6;
    }

    .projects__inner {
      width: clamp(280px, 92vw, 1180px);
      margin: 0 auto clamp(4px, 1.2vh, 10px);
      padding: 0 clamp(8px, 5vw, 32px);
      text-align: center;
    }

    .projects__tag {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: .45rem;
      padding: .6rem 1.35rem;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, .35);
      background: color-mix(in oklab, var(--surface, #101828) 55%, transparent);
      color: rgba(248, 250, 252, .96);
      font-size: clamp(.9rem, .85rem + .25vw, 1rem);
      font-weight: 500;
      letter-spacing: .03em;
      text-transform: none;
      width: fit-content;
      margin: 0 auto;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, .06);
    }

    :root:not(.dark) .projects__tag {
      color: rgba(15, 23, 42, .92);
      background: rgba(255, 255, 255, .94);
      border-color: rgba(15, 23, 42, .1);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, .9);
    }

    .projects__title {
      font-weight: 600;
      font-size: clamp(1.8rem, 3.2vw + .6rem, 2.6rem);
      line-height: 1.15;
      margin: clamp(12px, 2.4vh, 18px) auto clamp(10px, 2.4vh, 14px);
      max-width: 28ch;
    }

    .projects__title .highlight {
      background-image: linear-gradient(90deg, #26d2f8, #23b2ff, #0973e1 70%, #3b5bff);
     -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .projects__subtitle {
      color: color-mix(in oklab, var(--color-text) 60%, transparent);
      max-width: 60ch;
      margin: 0 auto clamp(20px, 6vh, 40px);
      font-size: clamp(1rem, .9rem + .25vw, 1.1rem);
      font-weight: 300;
    }

    .projects__grid {
      
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: clamp(16px, 2.8vw, 28px);
    }

    .project-card {
      position: relative;
      background: color-mix(in oklab, var(--surface, #121826) 65%, transparent);
      border-radius: 24px;
      border: 1px solid rgba(148, 163, 184, .18);
      box-shadow: 0 24px 60px rgba(15, 23, 42, .3), inset 0 1px 0 rgba(255, 255, 255, .06);
      transition: transform .2s ease, box-shadow .25s ease, border-color .25s ease;
      display: flex;
      flex-direction: column;
    }

    .project-card:hover {
      transform: translateY(-6px);
      border-color: color-mix(in oklab, var(--color-primary) 26%, rgba(148, 163, 184, .16));
      box-shadow:
        0 28px 70px color-mix(in oklab, var(--color-primary) 24%, rgba(15, 23, 42, .32)),
        inset 0 1px 0 rgba(255, 255, 255, .1);
    }

    :root:not(.dark) .project-card {
      background: rgba(255, 255, 255, .94);
      border-color: rgba(203, 213, 225, .6);
      box-shadow: 0 16px 40px rgba(15, 23, 42, .12), inset 0 1px 0 rgba(255, 255, 255, .65);
    }

    :root:not(.dark) .project-card:hover {
      border-color: rgba(148, 163, 184, .6);
      box-shadow: 0 24px 52px rgba(15, 23, 42, .16), inset 0 1px 0 rgba(255, 255, 255, .85);
    }

    .project-card__media {
      margin: clamp(18px, 2.5vw, 24px);
      border-radius: 18px;
      overflow: hidden;
      position: relative;
      aspect-ratio: 4 / 3;
      background: radial-gradient(circle at 30% 20%, rgba(96, 165, 250, .18), transparent 70%);
    }

    .project-card__media img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .project-card__body {
      padding: 0 clamp(16px, 2.5vw, 24px) clamp(20px, 2.8vw, 28px);
      color: rgba(226, 232, 240, .9);
      text-align: left;
      display: flex;
      flex-direction: column;
      gap: clamp(10px, 2vh, 14px);
    }

    :root:not(.dark) .project-card__body {
      color: rgba(30, 41, 59, .85);
    }

    .project-card__heading {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .project-card__heading h3 {
      font-size: clamp(1.05rem, 1rem + .4vw, 1.3rem);
      font-weight: 600;
      color: #fff;
      margin: 0;
    }

    :root:not(.dark) .project-card__heading h3 {
      color: #0f172a;
    }

    .project-card__pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: .35rem .8rem;
      border-radius: 999px;
      background: rgba(96, 165, 250, .16);
      color: #bae6fd;
      font-size: .78rem;
      font-weight: 400;
      white-space: nowrap;
    }

    :root:not(.dark) .project-card__pill {
      background: rgba(37, 99, 235, .12);
      color: #2563eb;
    }

    .project-card__description {
      font-size: .9rem;
      color: rgba(226, 232, 240, .75);
      line-height: 1.55;
    }

    :root:not(.dark) .project-card__description {
      color: rgba(30, 41, 59, .72);
    }

    .project-card__link {
      display: inline-flex;
      align-items: center;
      gap: .4rem;
      color: #93c5fd;
      font-weight: 600;
      text-decoration: none;
      font-size: .9rem;
    }

    .project-card__link:hover {
      color: #bfdbfe;
    }

    :root:not(.dark) .project-card__link {
      color: #2563eb;
    }

    :root:not(.dark) .project-card__link:hover {
      color: #1d4ed8;
    }

    .projects__cta {
      margin: clamp(32px, 8vh, 48px) auto 0;
    }

    .projects__button {
      display: inline-flex;
      align-items: center;
      gap: .65rem;
      padding: .85rem 1.6rem;
      border-radius: 999px;
      background: linear-gradient(90deg, #2563eb, #6366f1);
      color: #fff;
      text-decoration: none;
      font-weight: 600;
      box-shadow: 0 18px 28px rgba(37, 99, 235, .35);
      transition: transform .18s ease, box-shadow .22s ease;
    }

    .projects__button:hover {
      transform: translateY(-2px);
      box-shadow: 0 28px 40px rgba(79, 70, 229, .38);
    }

    :root:not(.dark) .projects__button {
      background: linear-gradient(90deg, #2563eb, #4f46e5);
      box-shadow: 0 16px 32px rgba(79, 70, 229, .25);
    }

    @media (max-width: 720px) {
      .projects {
        padding: clamp(28px, 12vh, 52px) 0 clamp(24px, 12vh, 44px);
      }

      .projects__inner {
        text-align: center;
      }

      .project-card__heading {
        flex-direction: column;
        align-items: flex-start;
      }
    }

    @media (max-width: 520px) {
      .projects__grid {
        grid-template-columns: 1fr;
      }

      .projects__subtitle {
        margin-bottom: clamp(20px, 6vh, 32px);
      }
    }
  </style>
</section>










