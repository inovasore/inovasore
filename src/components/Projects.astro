---
import { projects } from "../data/projects";
import { Image } from "astro:assets";
---

<section class="projects" id="proyectos">
  <div class="projects__halo" aria-hidden="true"></div>
  <img
    src="/Grilla02.svg"
    alt=""
    width="745"
    height="745"
    class="projects__grid-decoration projects__grid-decoration--left"
    aria-hidden="true"
  />
  <img
    src="/Grilla02.svg"
    alt=""
    width="745"
    height="745"
    class="projects__grid-decoration projects__grid-decoration--right"
    aria-hidden="true"
  />
  <div class="projects__inner">
    <span
      class="section-tag projects__tag projects__tag--dark reveal"
      style="--reveal-delay:.06s;--reveal-duration:.45s;--reveal-distance:10px"
    >
      Proyectos
    </span>
    <h2
      class="projects__title reveal"
      style="--reveal-delay:.14s;--reveal-duration:.55s;--reveal-distance:14px"
    >
      ¡Proyectos <span class="highlight">que dan resultados!</span>
    </h2>
    <p
      class="projects__subtitle reveal"
      style="--reveal-delay:.22s;--reveal-duration:.45s;--reveal-distance:10px"
    >
      Diseñamos experiencias digitales para marcas que confían en nuestra
      capacidad para crear estrategias y visuales impactantes.
    </p>

    <div class="projects__nav-wrapper">
      <button
        class="projects__nav-btn projects__nav-btn--prev"
        aria-label="Proyecto anterior"
        id="prevBtn"
      >
        <img src="/Raw01.svg" alt="" width="24" height="24" />
      </button>

      <div class="projects__grid">
        {
          projects.map((project, index) => (
            <article
              class="project-card reveal"
              data-index={index}
              style={`--reveal-delay:${(0.16 + (index % 3) * 0.08).toFixed(2)}s;--reveal-duration:.45s;--reveal-distance:12px; display: ${index < 3 ? "flex" : "none"};`}
            >
              >
              <figure class="project-card__media">
                <Image
                  src={project.image}
                  alt={project.title}
                  loading="lazy"
                  decoding="async"
                />
              </figure>
              <div class="project-card__body">
                <div class="project-card__heading">
                  <h3>{project.title}</h3>
                  <span class="project-card__pill">{project.category}</span>
                </div>
                <p class="project-card__description">{project.description}</p>
                <a class="project-card__link" href={project.url}>
                  Solicita un proyecto similar
                  <span class="material-symbols-rounded" aria-hidden="true">
                    arrow_outward
                  </span>
                </a>
              </div>
            </article>
          ))
        }
      </div>

      <button
        class="projects__nav-btn projects__nav-btn--next"
        aria-label="Siguiente proyecto"
        id="nextBtn"
      >
        <img src="/Raw02.svg" alt="" width="24" height="24" />
      </button>
    </div>
  </div>

  <script>
    const prevBtn = document.getElementById(
      "prevBtn",
    ) as HTMLButtonElement | null;
    const nextBtn = document.getElementById(
      "nextBtn",
    ) as HTMLButtonElement | null;
    const projectCards = document.querySelectorAll(".project-card");
    const VISIBLE_ITEMS = 3;
    const totalProjects = projectCards.length;
    let startIndex = 0;

    function updateProjects() {
      projectCards.forEach((card, index) => {
        const htmlCard = card as HTMLElement;
        let isVisible = false;
        let visualOrder = -1;

        // Check if this card should be visible and calculate its visual order
        for (let i = 0; i < VISIBLE_ITEMS; i++) {
          const visibleIndex = (startIndex + i) % totalProjects;
          if (index === visibleIndex) {
            isVisible = true;
            visualOrder = i;
            break;
          }
        }

        if (isVisible) {
          htmlCard.style.display = "flex";
          htmlCard.style.order = visualOrder.toString();
        } else {
          htmlCard.style.display = "none";
          htmlCard.style.order = "999";
        }
      });
    }

    prevBtn?.addEventListener("click", () => {
      startIndex = (startIndex - 1 + totalProjects) % totalProjects;
      updateProjects();
    });

    nextBtn?.addEventListener("click", () => {
      startIndex = (startIndex + 1) % totalProjects;
      updateProjects();
    });

    // Initialize
    updateProjects();
  </script>

  <style>
    .projects {
      position: relative;
      padding: calc(var(--section-padding-y) * 1.5) 0
        calc(var(--section-padding-y) * 1.5);
      background: #ffffff; /* Fondo claro */
      color: #1a1a2e; /* Texto oscuro */
      overflow: visible;
      isolation: isolate;
      margin: 0;
    }

    .projects__halo {
      display: none; /* Ocultar halo en tema claro */
    }

    .projects__grid-decoration {
      position: absolute;
      width: 600px;
      height: auto;
      opacity: 1;
      pointer-events: none;
      z-index: 0;
    }

    .projects__grid-decoration--left {
      left: -50px;
      top: 50%;
      transform: translateY(-50%) scaleX(-1);
    }

    .projects__grid-decoration--right {
      right: -50px;
      top: 50%;
      transform: translateY(-50%);
    }

    .projects__inner {
      position: relative;
      z-index: 1;
      width: clamp(280px, 92vw, 1180px);
      margin: 0 auto clamp(4px, 1.2vh, 10px);
      padding: 0 clamp(8px, 5vw, 32px);
      text-align: center;
    }

    .projects__title {
      font-weight: 600;
      font-size: clamp(1.8rem, 3.2vw + 0.6rem, 2.6rem);
      line-height: 1.15;
      margin: clamp(12px, 2.4vh, 18px) auto clamp(10px, 2.4vh, 14px);
      max-width: 28ch;
      color: #1a1a2e;
    }

    .projects__title .highlight {
      background-image: linear-gradient(
        90deg,
        #26d2f8,
        #23b2ff,
        #0973e1 70%,
        #3b5bff
      );
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .projects__subtitle {
      color: rgba(30, 30, 60, 0.65);
      max-width: 60ch;
      margin: 0 auto clamp(20px, 6vh, 40px);
      font-size: clamp(1rem, 0.9rem + 0.25vw, 1.1rem);
      font-weight: 400;
    }

    .projects__tag--dark {
      color: #000000;
      opacity: 1;
    }

    .projects__nav-wrapper {
      display: flex;
      align-items: center;
      gap: clamp(16px, 2vw, 32px);
      justify-content: center;
    }

    .projects__nav-btn {
      flex-shrink: 0;
      width: 48px;
      height: 48px;
      border-radius: 50%;
      border: 1px solid rgba(30, 30, 60, 0.15);
      background: #ffffff;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.2s ease;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    }

    .projects__nav-btn:disabled {
      cursor: not-allowed;
    }

    .projects__nav-btn:hover {
      border-color: rgba(59, 91, 255, 0.3);
      box-shadow: 0 4px 16px rgba(59, 91, 255, 0.12);
    }

    .projects__nav-btn img {
      width: 20px;
      height: 20px;
      object-fit: contain;
    }

    .projects__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr); /* Exactamente 3 columnas */
      gap: clamp(16px, 2.8vw, 28px);
      justify-items: stretch;
      flex: 1;
      max-width: 1000px;
    }

    .project-card {
      --project-card-radius: clamp(18px, 2.6vw, 24px);
      position: relative;
      background: #ffffff;
      border-radius: var(--project-card-radius);
      border: 1px solid rgba(30, 30, 60, 0.1);
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
      transition:
        transform 0.2s ease,
        box-shadow 0.25s ease,
        border-color 0.25s ease;
      display: flex;
      flex-direction: column;
    }

    .project-card:hover {
      transform: translateY(-6px);
      border-color: rgba(59, 91, 255, 0.25);
      box-shadow: 0 12px 40px rgba(59, 91, 255, 0.12);
    }

    .project-card__media {
      margin: clamp(16px, 2.4vw, 24px);
      border-radius: calc(var(--project-card-radius, 24px) - 4px);
      overflow: hidden;
      position: relative;
      aspect-ratio: 4 / 3;
      background: #f1f5f9;
    }

    .project-card__media img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .project-card__body {
      padding: 0 clamp(16px, 2.5vw, 24px) clamp(20px, 2.8vw, 28px);
      color: #1a1a2e;
      text-align: left;
      display: flex;
      flex-direction: column;
      gap: clamp(10px, 2vh, 14px);
    }

    .project-card__heading {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .project-card__heading h3 {
      font-size: clamp(1.05rem, 1rem + 0.4vw, 1.3rem);
      font-weight: 600;
      color: #1a1a2e;
      margin: 0;
    }

    .project-card__pill {
      display: none; /* Ocultar pill en este diseño */
    }

    .project-card__description {
      font-size: 0.9rem;
      color: rgba(30, 30, 60, 0.7);
      line-height: 1.55;
    }

    .project-card__link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
      padding: 0.6rem 1.2rem;
      border: 1px solid rgba(59, 91, 255, 0.4);
      border-radius: 999px;
      color: #3b5bff;
      font-weight: 500;
      text-decoration: none;
      font-size: 0.85rem;
      transition: all 0.2s ease;
      width: fit-content;
    }

    .project-card__link:hover {
      background: rgba(59, 91, 255, 0.08);
      border-color: #3b5bff;
    }

    @media (max-width: 720px) {
      .projects {
        padding: var(--section-padding-y-tight) 0;
      }

      .projects__inner {
        text-align: center;
      }

      .project-card__heading {
        flex-direction: column;
        align-items: flex-start;
      }
    }

    @media (max-width: 640px) {
      .projects {
        padding-top: calc(var(--section-padding-y) * 2.5);
      }

      .projects__nav-wrapper {
        display: block;
      }

      .projects__nav-btn {
        display: none !important;
      }

      .projects__grid {
        display: flex;
        flex-direction: row; /* Cambiar a fila para horizontal */
        flex-wrap: nowrap; /* No envolver */
        gap: 16px;
        max-width: 100%;
        width: 100%;
        margin-inline: auto;
        overflow-x: auto; /* Permitir scroll horizontal */
        scroll-snap-type: x mandatory; /* Snap al deslizar */
        padding: 0 16px 20px; /* Padding lateral y espacio abajo */
        -webkit-overflow-scrolling: touch;
      }

      /* Ocultar barra de scroll */
      .projects__grid::-webkit-scrollbar {
        display: none;
      }
      .projects__grid {
        -ms-overflow-style: none; /* IE and Edge */
        scrollbar-width: none; /* Firefox */
      }

      .project-card {
        flex: 0 0 88%; /* Tarjeta ocupa 88% del ancho */
        width: 88%;
        display: flex !important;
        order: unset !important;
        scroll-snap-align: center; /* Centrar al soltar */
      }

      .projects__grid-decoration {
        width: 400px; /* Reducir tamaño de grilla en móvil */
        height: auto;
      }

      .project-card__media {
        aspect-ratio: 16 / 10;
        margin: clamp(16px, 4vw, 20px);
      }

      .project-card__body {
        padding: 0 clamp(16px, 4vw, 20px) clamp(20px, 5vw, 24px);
      }
    }

    @media (max-width: 520px) {
      .projects__subtitle {
        margin-bottom: clamp(20px, 6vh, 32px);
      }
    }

    @media (max-width: 400px) {
      .projects__inner {
        padding-inline: clamp(12px, 7vw, 18px);
      }

      .project-card__media {
        aspect-ratio: 16 / 9;
      }
    }
  </style>
</section>
