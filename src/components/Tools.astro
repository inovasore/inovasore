---
---

<section class="tools" id="herramientas">
  <div class="tools__bg" aria-hidden="true"></div>
  <div class="section-inner section-inner--center tools__inner">
    <div
      class="section-tag tools__tag reveal"
      style="--reveal-delay:.06s;--reveal-duration:.45s;--reveal-distance:10px"
    >
      Herramientas
    </div>
    <h2
      class="tools__title reveal"
      style="--reveal-delay:.14s;--reveal-duration:.55s;--reveal-distance:12px"
    >
      Herramientas que <span class="highlight">impulsan nuestro trabajo</span>
    </h2>
    <p
      class="tools__subtitle reveal"
      style="--reveal-delay:.22s;--reveal-duration:.45s;--reveal-distance:10px"
    >
      Aprovechamos un stack moderno para diseñar, desarrollar y publicar sitios veloces, escalables y fáciles de editar.
    </p>

    <div class="tools__grid">
      <a
        class="tools__card reveal"
        href="https://www.figma.com/"
        target="_blank"
        rel="noopener noreferrer"
        style="--reveal-delay:.06s;--reveal-duration:.4s;--reveal-distance:10px"
      >
        <div class="tools__icon">
          <img src="/Figma.svg" alt="Figma" loading="lazy" width="28" height="28" />
        </div>
        <div class="tools__open" aria-hidden="true">
          <span class="material-symbols-rounded">arrow_outward</span>
        </div>
        <h3 class="tools__card-title">Figma</h3>
        <p class="tools__card-desc">
          Diseño colaborativo y prototipado profesional. Componentes, auto-layout y Dev Mode para un handoff sin fricción.
        </p>
      </a>

      <a
        class="tools__card reveal"
        href="https://astro.build/"
        target="_blank"
        rel="noopener noreferrer"
        style="--reveal-delay:.12s;--reveal-duration:.4s;--reveal-distance:10px"
      >
        <div class="tools__icon">
          <img src="/Astro.svg" alt="Astro" loading="lazy" width="28" height="28" />
        </div>
        <div class="tools__open" aria-hidden="true">
          <span class="material-symbols-rounded">arrow_outward</span>
        </div>
        <h3 class="tools__card-title">Astro</h3>
        <p class="tools__card-desc">
          Framework ultra-rápido con islas de UI, SSR/SSG y SEO de primera. Perfecto para sitios ligeros y escalables.
        </p>
      </a>

      <a
        class="tools__card reveal"
        href="https://react.dev/"
        target="_blank"
        rel="noopener noreferrer"
        style="--reveal-delay:.18s;--reveal-duration:.4s;--reveal-distance:10px"
      >
        <div class="tools__icon">
          <img src="/React.svg" alt="React" loading="lazy" width="28" height="28" />
        </div>
        <div class="tools__open" aria-hidden="true">
          <span class="material-symbols-rounded">arrow_outward</span>
        </div>
        <h3 class="tools__card-title">React</h3>
        <p class="tools__card-desc">
          Interfaces dinámicas con componentes reutilizables y hooks. Interactividad precisa y rendimiento consistente.
        </p>
      </a>

      <a
        class="tools__card reveal"
        href="https://elementor.com/"
        target="_blank"
        rel="noopener noreferrer"
        style="--reveal-delay:.24s;--reveal-duration:.4s;--reveal-distance:10px"
      >
        <div class="tools__icon">
          <img src="/Elementor.svg" alt="Elementor" loading="lazy" width="28" height="28" />
        </div>
        <div class="tools__open" aria-hidden="true">
          <span class="material-symbols-rounded">arrow_outward</span>
        </div>
        <h3 class="tools__card-title">Elementor</h3>
        <p class="tools__card-desc">
          Constructor visual para WordPress. Landing pages, Theme Builder y contenido dinámico sin tocar código.
        </p>
      </a>

      <a
        class="tools__card reveal"
        href="https://webflow.com/"
        target="_blank"
        rel="noopener noreferrer"
        style="--reveal-delay:.30s;--reveal-duration:.4s;--reveal-distance:10px"
      >
        <div class="tools__icon">
          <img src="/Webflow.svg" alt="Webflow" loading="lazy" width="28" height="28" />
        </div>
        <div class="tools__open" aria-hidden="true">
          <span class="material-symbols-rounded">arrow_outward</span>
        </div>
        <h3 class="tools__card-title">Webflow</h3>
        <p class="tools__card-desc">
          Desarrollo visual, CMS y hosting en un solo lugar. Animaciones nativas y control pixel-perfect del diseño.
        </p>
      </a>

      <a
        class="tools__card reveal"
        href="https://www.framer.com/"
        target="_blank"
        rel="noopener noreferrer"
        style="--reveal-delay:.36s;--reveal-duration:.4s;--reveal-distance:10px"
      >
        <div class="tools__icon">
          <img src="/Framer.svg" alt="Framer" loading="lazy" width="28" height="28" />
        </div>
        <div class="tools__open" aria-hidden="true">
          <span class="material-symbols-rounded">arrow_outward</span>
        </div>
        <h3 class="tools__card-title">Framer</h3>
        <p class="tools__card-desc">
          Prototipos y sitios con micro-interacciones fluidas. Animaciones de alto nivel y publicación instantánea.
        </p>
      </a>
    </div>
  </div>

  <style>
    .tools {
      position: relative;
      overflow: hidden;
      background: var(--color-bg);
      color: var(--color-text);
      isolation: isolate;
      margin: 0;
      padding: var(--section-padding-y) 0;
    }

    .tools__tag {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: .45rem;
      padding: .6rem 1.35rem;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, .35);
      background: color-mix(in oklab, var(--surface, #101828) 55%, transparent);
      color: rgba(248, 250, 252, .96);
      font-size: clamp(.9rem, .85rem + .25vw, 1rem);
      font-weight: 500;
      letter-spacing: .03em;
      text-transform: none;
      width: fit-content;
      margin: 0 auto;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, .06);
    }

    :root:not(.dark) .tools__tag {
      color: rgba(15, 23, 42, .92);
      background: rgba(255, 255, 255, .94);
      border-color: rgba(15, 23, 42, .1);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, .9);
    }

    .tools__title {
      font-weight: 600;
      font-size: clamp(1.8rem, 3.2vw + .6rem, 2.6rem);
      line-height: 1.15;
      margin: clamp(12px, 2.4vh, 18px) auto clamp(10px, 2.4vh, 18px);
      max-width: 28ch;
    }

    .tools__title .highlight {
      display: inline-block;
      background-image: linear-gradient(90deg, #26d2f8, #23b2ff, #0973e1 70%, #3b5bff);
      background-size: 100% 100%;
      background-repeat: no-repeat;
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent !important;
      -webkit-text-fill-color: transparent !important;
    }

    .tools__subtitle {
      color: color-mix(in oklab, var(--color-text) 60%, transparent);
      max-width: 60ch;
      margin: 0 auto clamp(26px, 6vh, 40px);
      font-size: clamp(1rem, .9rem + .25vw, 1.1rem);
      font-weight: 300;
    }

    .tools__grid {
      display: grid;
      gap: 18px;
      grid-template-columns: 1fr;
      margin-top: clamp(24px, 4vw, 40px);
    }

    @media (min-width: 740px) {
      .tools__grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 1024px) {
      .tools__grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    .tools__card {
      position: relative;
      text-align: left;
      padding: 20px 22px;
      border-radius: 18px;
      border: 1px solid var(--border);
      background: linear-gradient(
        180deg,
        color-mix(in oklab, var(--surface, #121826) 60%, transparent),
        color-mix(in oklab, var(--surface, #121826) 55%, transparent)
      );
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, .06);
      transition: transform .18s ease, box-shadow .25s ease, border-color .25s ease;
      text-decoration: none;
      color: inherit;
    }

    .tools__card::before {
      content: "";
      position: absolute;
      top: 0;
      left: 18px;
      height: 4px;
      width: 76px;
      border-radius: 0 0 8px 8px;
      pointer-events: none;
      z-index: 2;
      background: linear-gradient(90deg, #0973e1, #0446ba);
      box-shadow: 0 8px 18px rgba(9, 115, 225, .35);
      opacity: .95;
    }

    .tools__card::after {
      content: "";
      position: absolute;
      inset: -1px;
      border-radius: inherit;
      pointer-events: none;
      z-index: 1;
      background:
        radial-gradient(420px 260px at 110% 120%, color-mix(in oklab, var(--color-primary) 22%, transparent), transparent 60%),
        radial-gradient(300px 220px at -8% 12%, color-mix(in oklab, var(--color-primary-dark) 14%, transparent), transparent 72%);
      mix-blend-mode: screen;
      opacity: .22;
      transition: opacity .25s ease;
    }

    .tools__card:hover {
      transform: translateY(-2px);
      border-color: color-mix(in oklab, var(--color-primary) 40%, var(--border));
      box-shadow:
        var(--shadow-elevated),
        0 14px 36px color-mix(in oklab, var(--color-primary) 18%, transparent),
        inset 0 1px 0 rgba(255, 255, 255, .06);
      filter: saturate(112%) brightness(1.02);
    }

    .tools__open {
      position: absolute;
      right: 14px;
      top: 12px;
      width: 34px;
      height: 34px;
      display: grid;
      place-items: center;
      border-radius: 999px;
      opacity: .8;
      background: color-mix(in oklab, var(--surface, #121826) 40%, transparent);
      border: 1px solid var(--border);
      color: var(--color-text-muted, #94a3b8);
    }

    .tools__card:hover .tools__open {
      opacity: 1;
    }

    .tools__icon {
      display: inline-grid;
      place-items: center;
      margin-bottom: 8px;
      width: auto;
      height: auto;
      border-radius: 0;
      background: transparent;
      border: 0;
      box-shadow: none;
      color: inherit;
    }

    .tools__icon img {
      width: 28px;
      height: 28px;
      object-fit: contain;
    }

    .tools__card-title {
      font-size: 1.15rem;
      font-weight: 600;
      color: #fff;
    }

    :root:not(.dark) .tools__card-title {
      color: #0f172a;
    }

    .tools__card-desc {
      color: var(--color-text-muted, #9ca3af);
      font-size: .98rem;
      margin-top: .35rem;
    }

    :root:not(.dark) .tools__card-desc {
      color: #334155;
    }

    .dark .tools__card-desc {
      color: #d6e0ef;
    }

    :root:not(.dark) .tools__card {
      background: linear-gradient(180deg, #ffffff, #f1f5f9);
      border-color: rgba(0, 0, 0, .12);
      box-shadow: 0 1px 2px rgba(0, 0, 0, .06), inset 0 1px 0 rgba(255, 255, 255, 0);
    }

    :root:not(.dark) .tools__open {
      background: rgba(17, 24, 39, .05);
      color: #334155;
      border-color: rgba(0, 0, 0, .12);
    }

    .tools__bg {
      position: absolute;
      inset: -10% -10% 0 -10%;
      pointer-events: none;
      z-index: -1;
      display: none;
    }

    .tools__bg::before,
    .tools__bg::after {
      content: "";
      position: absolute;
      inset: -1px;
      border-radius: 50%;
      filter: blur(70px);
      opacity: .35;
    }

    .tools__bg::before {
      background:
        radial-gradient(1200px 600px at 85% 70%, color-mix(in oklab, var(--color-primary) 18%, transparent), transparent 60%),
        radial-gradient(800px 520px at 10% 20%, color-mix(in oklab, var(--color-primary) 8%, transparent), transparent 70%);
    }

    .tools__bg::after {
      background:
        radial-gradient(900px 520px at 12% 24%, color-mix(in oklab, var(--color-primary-dark) 12%, transparent), transparent 70%);
    }

    .dark .tools__bg {
      display: block;
    }

    .dark .tools__card {
      border-color: rgba(255, 255, 255, .08);
      background: linear-gradient(180deg, rgba(12, 14, 22, .92), rgba(12, 14, 22, .86));
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, .03);
    }

    .dark .tools__card:hover {
      border-color: rgba(59, 130, 246, .35);
      box-shadow: 0 10px 30px rgba(0, 0, 0, .25), inset 0 1px 0 rgba(255, 255, 255, .04);
    }
  </style>
</section>
