---
const links = [
  { href: "/", label: "Inicio" },
  { href: "/servicios", label: "Servicios" },
  { href: "/#proyectos", label: "Proyectos" },
  { href: "/#faq", label: "FAQ" },
  { href: "/#nosotros", label: "Nosotros" },
];
---

<nav class="navbar" data-nav>
  <div class="nav-content">
    <a href="/" class="logo" aria-label="Inovasore, ir al inicio">
      <img src="/Logotipo.svg" alt="Logotipo de Inovasore" />
      <span class="name">Inovasore</span>
    </a>

    <div class="nav-controls">
      <button
        class="btn-theme btn-theme--mobile"
        type="button"
        aria-label="Cambiar tema"
        aria-pressed="false"
        data-theme-toggle
      >
        <span class="icon icon-light material-symbols-rounded" aria-hidden="true">light_mode</span>
        <span class="icon icon-dark material-symbols-rounded" aria-hidden="true">dark_mode</span>
      </button>

      <button class="nav-toggle" type="button" aria-label="Abrir menú" aria-expanded="false" aria-controls="primary-navigation">
        <span class="material-symbols-rounded nav-toggle__icon nav-toggle__icon--open" aria-hidden="true">menu</span>
        <span class="material-symbols-rounded nav-toggle__icon nav-toggle__icon--close" aria-hidden="true">close</span>
      </button>
    </div>

    <div class="nav-menu" id="primary-navigation" role="navigation">
      <ul class="nav-links">
        {links.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
      <div class="nav-actions">
        <a href="/contacto" class="btn">Contacto</a>
        <button class="btn-theme btn-theme--desktop" aria-label="Cambiar tema" aria-pressed="false" data-theme-toggle>
          <span class="icon icon-light material-symbols-rounded" aria-hidden="true">light_mode</span>
          <span class="icon icon-dark material-symbols-rounded" aria-hidden="true">dark_mode</span>
        </button>
      </div>
    </div>
  </div>
  <div class="nav-backdrop" aria-hidden="true"></div>
</nav>

<script is:inline>
  window.addEventListener('DOMContentLoaded', () => {
    const nav = document.querySelector('[data-nav]');
    if (!nav) return;

    const toggle = nav.querySelector('.nav-toggle');
    const menu = nav.querySelector('.nav-menu');
    const backdrop = nav.querySelector('.nav-backdrop');

    const closeMenu = () => {
      nav.classList.remove('navbar--open');
      toggle?.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('nav-open');
    };

    const focusFirst = () => {
      const focusable = menu?.querySelector('a, button');
      if (focusable instanceof HTMLElement) {
        focusable.focus({ preventScroll: true });
      }
    };

    const openMenu = () => {
      nav.classList.add('navbar--open');
      toggle?.setAttribute('aria-expanded', 'true');
      document.body.classList.add('nav-open');
      focusFirst();
    };

    const handleToggle = () => {
      if (nav.classList.contains('navbar--open')) {
        closeMenu();
      } else {
        openMenu();
      }
    };

    const handleMenuClick = (event) => {
      const target = event.target;
      if (target instanceof Element && target.closest('a')) {
        closeMenu();
      }
    };

    const handleBackdrop = () => closeMenu();

    const handleKeydown = (event) => {
      if (event.key === 'Escape') {
        closeMenu();
      }
    };

    toggle?.addEventListener('click', handleToggle);
    menu?.addEventListener('click', handleMenuClick);
    backdrop?.addEventListener('click', handleBackdrop);
    document.addEventListener('keydown', handleKeydown);

    const mq = window.matchMedia('(max-width: 960px)');
    const handleMedia = (event) => {
      if (!event.matches) {
        closeMenu();
      }
    };
    if (mq) {
      if ('addEventListener' in mq) {
        mq.addEventListener('change', handleMedia);
      } else if ('addListener' in mq) {
        mq.addListener(handleMedia);
      }
    }

    const cleanupNav = () => {
      closeMenu();
      toggle?.removeEventListener('click', handleToggle);
      menu?.removeEventListener('click', handleMenuClick);
      backdrop?.removeEventListener('click', handleBackdrop);
      document.removeEventListener('keydown', handleKeydown);
      if (mq) {
        if ('removeEventListener' in mq) {
          mq.removeEventListener('change', handleMedia);
        } else if ('removeListener' in mq) {
          mq.removeListener(handleMedia);
        }
      }
    };

    document.addEventListener('astro:before-swap', cleanupNav, { once: true });
    window.addEventListener('beforeunload', cleanupNav, { once: true });

    const root = document.documentElement;
    const themeButtons = nav.querySelectorAll('[data-theme-toggle]');

    if (themeButtons.length) {
      const handleThemeToggle = () => {
        root.classList.add('theme-switching');
        const toDark = !root.classList.contains('dark');
        root.classList.toggle('dark', toDark);
        localStorage.setItem('theme', toDark ? 'dark' : 'light');
        themeButtons.forEach((btn) => btn.setAttribute('aria-pressed', String(toDark)));
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            root.classList.remove('theme-switching');
          });
        });
      };

      const updatePressed = () => {
        const pressed = root.classList.contains('dark');
        themeButtons.forEach((btn) => btn.setAttribute('aria-pressed', String(pressed)));
      };

      updatePressed();
      themeButtons.forEach((btn) => btn.addEventListener('click', handleThemeToggle));

      const cleanupTheme = () => {
        themeButtons.forEach((btn) => btn.removeEventListener('click', handleThemeToggle));
      };

      document.addEventListener('astro:before-swap', cleanupTheme, { once: true });
      window.addEventListener('beforeunload', cleanupTheme, { once: true });


    }
  });
</script>



