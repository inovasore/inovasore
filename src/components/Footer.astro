---
import { footerData } from "../data/footer";

const year = new Date().getFullYear();
const phone = footerData.contact.phone?.trim();
const phoneHref = phone ? `tel:${phone.replace(/\s+/g, "")}` : null;
---

<footer class="footer" aria-labelledby="site-footer-heading">
  <div class="section-inner footer__inner">
    <div class="footer__main">
      <div class="footer__contact">
        <h2
          id="site-footer-heading"
          class="footer__heading footer__heading--logo"
          aria-label={footerData.contact.headline}
        >
          <img src="/Logotipo.svg" alt="Inovasore" width="32" height="32" />
          <span class="footer__heading--logo-text">{footerData.agency.name}</span>
        </h2>
        <address>
          {footerData.contact.addressLines.map((line) => (
            <span>{line}</span>
          ))}
          {phone && phoneHref && (
            <a href={phoneHref}>
              {phone}
            </a>
          )}
          <span>{footerData.contact.serviceArea}</span>
        </address>
      </div>

      <div class="footer__about">
        <h3>Sobre Inovasore</h3>
        <p>{footerData.agency.description}</p>
        <a
          class="footer__whatsapp"
          href={footerData.contact.whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="material-symbols-rounded" aria-hidden="true">chat</span>
          Escr&iacute;benos por WhatsApp
        </a>
      </div>

      <div class="footer__cta">
        <div class="footer__social footer__social--cta" aria-label="Redes sociales">
          {footerData.socialLinks.map((social) => (
            <a
              class="footer__social-link"
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`Inovasore en ${social.label}`}
            >
              <span class="footer__social-icon" aria-hidden="true">
                {(() => {
                  switch (social.icon) {
                    case "whatsapp":
                      return (
                        <svg viewBox="0 0 24 24">
                          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z" />
                        </svg>
                      );
                    case "instagram":
                      return (
                        <svg viewBox="0 0 24 24">
                          <path d="M7.03.084c-1.277.06-2.149.264-2.911.563-.789.308-1.458.72-2.123 1.388-.665.668-1.075 1.337-1.38 2.127-.296.764-.496 1.637-.552 2.914-.057 1.278-.069 1.688-.063 4.947.006 3.259.02 3.667.083 4.947.061 1.277.264 2.149.563 2.911.308.789.72 1.457 1.388 2.123.668.665 1.337 1.074 2.129 1.38.763.295 1.636.496 2.913.552 1.277.056 1.689.069 4.947.063 3.258-.006 3.668-.021 4.948-.082 1.28-.061 2.147-.265 2.91-.563.789-.309 1.458-.72 2.123-1.389.665-.668 1.075-1.338 1.38-2.129.296-.763.497-1.636.552-2.912.056-1.281.069-1.69.063-4.948-.006-3.258-.021-3.667-.082-4.947-.061-1.28-.264-2.149-.563-2.912-.308-.789-.72-1.457-1.388-2.123C21.298 1.33 20.628.92 19.838.617c-.764-.296-1.636-.497-2.914-.552C15.647.009 15.236-.005 11.977 0 8.718.008 8.31.021 7.03.084m.14 21.693c-1.17-.051-1.805-.245-2.229-.408-.56-.216-.959-.477-1.381-.895-.422-.418-.681-.819-.9-1.378-.165-.423-.363-1.058-.418-2.228-.06-1.265-.072-1.645-.078-4.848-.007-3.204.005-3.583.06-4.848.05-1.17.246-1.805.408-2.228.216-.562.477-.96.895-1.382.419-.422.818-.681 1.378-.9.423-.165 1.058-.361 2.227-.417 1.266-.06 1.645-.072 4.848-.079 3.203-.007 3.584.005 4.85.061 1.17.05 1.805.244 2.228.407.56.216.96.475 1.381.895.422.419.682.818.901 1.379.165.422.361 1.056.417 2.226.06 1.265.074 1.645.08 4.848.006 3.203-.006 3.584-.061 4.848-.051 1.17-.245 1.805-.408 2.229-.216.56-.476.96-.895 1.381-.419.422-.818.681-1.378.9-.423.165-1.058.362-2.226.417-1.266.06-1.645.072-4.85.079-3.204.007-3.582-.006-4.848-.06M16.953 5.586a1.44 1.44 0 1 0 1.437-1.442 1.44 1.44 0 0 0-1.437 1.442M5.839 12.012c.006 3.403 2.77 6.156 6.173 6.149 3.403-.007 6.157-2.77 6.15-6.173-.006-3.403-2.77-6.157-6.173-6.15-3.403.007-6.156 2.771-6.149 6.174M8 12.008a4 4 0 1 1 8.018-.016A4 4 0 0 1 8 12.008" />
                        </svg>
                      );
                    case "facebook":
                      return (
                        <svg viewBox="0 0 24 24">
                          <path d="M9.101 23.691v-7.98H6.627v-3.667h2.474v-1.58c0-4.085 1.848-5.978 5.858-5.978.401 0 .955.042 1.468.103.392.052.768.118 1.141.195v3.325a8.623 8.623 0 0 0-.653-.036c-.231-.007-.48-.01-.733-.01-.707 0-1.259.096-1.675.309a1.686 1.686 0 0 0-.679.622c-.258.42-.374.995-.374 1.752v1.297h3.919l-.673 3.667h-3.246v8.245C19.396 23.238 24 18.179 24 12.044 24 5.417 18.627.044 12 .044S0 5.417 0 12.044c0 5.628 3.874 10.35 9.101 11.647Z" />
                        </svg>
                      );
                    case "x":
                      return (
                        <svg viewBox="0 0 24 24">
                          <path d="M14.234 10.162 22.977 0h-2.072l-7.591 8.824L7.251 0H.258l9.168 13.343L.258 24H2.33l8.016-9.318L16.749 24h6.993zm-2.837 3.299-.929-1.329L3.076 1.56h3.182l5.965 8.532.929 1.329 7.754 11.09h-3.182z" />
                        </svg>
                      );
                    default:
                      return null;
                  }
                })()}
              </span>
            </a>
          ))}
        </div>
        <a class="footer__btn footer__btn--primary" href="#top">
          Volver arriba
        </a>
        <a class="footer__btn footer__btn--ghost" href="/contacto">
          Agenda una reuni&oacute;n
        </a>
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__copyright">
        &copy; {year} {footerData.agency.name}. Todos los derechos reservados.
      </p>
      <nav class="footer__quick-links" aria-label="Accesos r&aacute;pidos">
        {footerData.quickLinks.map((item) => (
          <a href={item.href}>{item.label}</a>
        ))}
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    margin-top: 0;
    padding: var(--section-padding-y) 0;
    background: color-mix(in oklab, var(--color-bg) 96%, rgba(15, 23, 42, 0.12));
    color: color-mix(in oklab, var(--color-text) 92%, transparent);
    border-top: 1px solid color-mix(in oklab, var(--border) 78%, transparent);
    overflow: hidden;
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: clamp(20px, 4vh, 36px);
  }

  .footer__social {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .footer__social--cta {
    margin-bottom: 0.35rem;
  }

  .footer__social-link {
    width: 34px;
    height: 34px;
    border-radius: 12px;
    border: 1px solid color-mix(in oklab, var(--color-primary) 35%, transparent);
    background: color-mix(in oklab, var(--surface, #ffffff) 85%, transparent);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: color-mix(in oklab, var(--color-primary) 80%, transparent);
    text-decoration: none;
    transition: transform 0.2s ease, border-color 0.2s ease, background-color 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 8px 18px rgba(37, 99, 235, 0.12);
  }

  .footer__social-link:hover,
  .footer__social-link:focus-visible {
    transform: translateY(-1px);
    border-color: color-mix(in oklab, var(--color-primary) 60%, transparent);
    background: color-mix(in oklab, var(--color-primary) 18%, rgba(59, 130, 246, 0.18));
    color: color-mix(in oklab, var(--color-primary) 92%, transparent);
    box-shadow: 0 10px 24px rgba(37, 99, 235, 0.2);
  }

  .footer__social-icon svg {
    width: 18px;
    height: 18px;
    display: block;
    fill: currentColor;
  }

  .dark .footer__social-link {
    border: 1px solid color-mix(in oklab, var(--color-primary) 55%, transparent);
    background: color-mix(in oklab, var(--color-primary) 32%, rgba(14, 165, 233, 0.2));
    color: #fff;
    box-shadow: 0 6px 18px rgba(59, 130, 246, 0.22);
  }

  .dark .footer__social-link:hover,
  .dark .footer__social-link:focus-visible {
    border-color: color-mix(in oklab, var(--color-primary) 80%, transparent);
    background: color-mix(in oklab, var(--color-primary) 45%, rgba(14, 165, 233, 0.35));
    color: #fff;
    box-shadow: 0 10px 24px rgba(59, 130, 246, 0.28);
  }

  .footer__main {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: clamp(14px, 3.5vw, 28px);
    position: relative;
    z-index: 1;
  }

  .footer__contact address {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    font-style: normal;
    color: color-mix(in oklab, var(--color-text) 75%, transparent);
    font-size: 0.86rem;
  }

  .footer__contact a {
    color: color-mix(in oklab, var(--color-primary) 85%, transparent);
    font-weight: 600;
    text-decoration: none;
  }

  .footer__contact a:hover,
  .footer__contact a:focus-visible {
    text-decoration: underline;
  }

  .footer__heading {
    margin: 0 0 0.75rem;
    font-size: clamp(0.98rem, 0.92rem + 0.28vw, 1.18rem);
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  .footer__heading--logo {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .footer__heading--logo img {
    width: clamp(22px, 2.8vw, 32px);
    height: auto;
    display: block;
  }

  .footer__heading--logo-text {
    font-size: clamp(0.94rem, 0.9rem + 0.24vw, 1.12rem);
    font-weight: 600;
    letter-spacing: 0.02em;
    color: color-mix(in oklab, var(--color-text) 95%, transparent);
  }

  .footer__about {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .footer__about h3 {
    font-size: clamp(0.94rem, 0.88rem + 0.2vw, 1.08rem);
    font-weight: 600;
  }

  .footer__about p {
    color: color-mix(in oklab, var(--color-text) 78%, transparent);
    line-height: 1.6;
    font-size: 0.86rem;
  }

  .footer__whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1rem;
    border-radius: 12px;
    background: color-mix(in oklab, var(--color-primary) 20%, transparent);
    color: color-mix(in oklab, var(--color-text) 92%, transparent);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    border: 1px solid color-mix(in oklab, var(--color-primary) 28%, transparent);
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .footer__whatsapp:hover,
  .footer__whatsapp:focus-visible {
    background: color-mix(in oklab, var(--color-primary) 45%, transparent);
    color: #fff;
    border-color: color-mix(in oklab, var(--color-primary) 55%, transparent);
  }

  .footer__whatsapp .material-symbols-rounded {
    font-size: 1rem;
  }

  .footer__cta {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    align-items: flex-start;
  }

  .footer__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 1.25rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .footer__btn--primary {
    background: var(--color-primary);
    color: #fff;
    border: 1px solid var(--color-primary);
    box-shadow: 0 12px 30px rgba(37, 99, 235, 0.32);
  }

  .footer__btn--primary:hover,
  .footer__btn--primary:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 16px 40px rgba(37, 99, 235, 0.4);
  }

  .footer__btn--ghost {
    background: color-mix(in oklab, var(--surface, #f3f4f6) 65%, transparent);
    border: 1px solid color-mix(in oklab, var(--border) 85%, transparent);
    color: color-mix(in oklab, var(--color-text) 90%, transparent);
  }

  .footer__btn--ghost:hover,
  .footer__btn--ghost:focus-visible {
    color: color-mix(in oklab, var(--color-primary) 85%, transparent);
    border-color: color-mix(in oklab, var(--color-primary) 35%, transparent);
    background: color-mix(in oklab, var(--surface, #f3f4f6) 85%, transparent);
  }

  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    border-top: 1px solid color-mix(in oklab, var(--border) 70%, transparent);
    padding-top: 0.9rem;
    font-size: 0.82rem;
    color: color-mix(in oklab, var(--color-text) 68%, transparent);
  }

  .footer__quick-links {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .footer__quick-links a {
    color: color-mix(in oklab, var(--color-text) 78%, transparent);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.84rem;
  }

  .footer__quick-links a:hover,
  .footer__quick-links a:focus-visible {
    color: color-mix(in oklab, var(--color-primary) 80%, transparent);
  }

  @media (max-width: 1120px) {
    .footer__main {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    }

    .footer__cta {
      grid-column: 1 / -1;
      align-items: center;
      text-align: center;
    }

    .footer__social--cta {
      justify-content: center;
      width: 100%;
    }
  }

  @media (max-width: 800px) {
    .footer {
      padding: var(--section-padding-y-tight) 0;
    }

    .footer__social {
      justify-content: center;
    }

    .footer__main {
      grid-template-columns: minmax(0, 1fr);
    }

    .footer__cta {
      align-items: stretch;
    }

    .footer__social--cta {
      justify-content: center;
      width: 100%;
    }

    .footer__bottom {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .footer__quick-links {
      justify-content: center;
      flex-wrap: wrap;
    }
  }

    @media (prefers-reduced-motion: reduce) {
      .footer__social-link,
      .footer__btn {
        transition: none;
      }

    .footer__social-link:hover,
    .footer__btn:hover {
      transform: none;
    }
    }

    @supports not (color: color-mix(in oklab, black 50%, white)) {
      .footer {
        background: #f8fafc;
        color: #0f172a;
        border-top: 1px solid rgba(15, 23, 42, 0.12);
      }
      .dark .footer {
        background: #050613;
        color: #f8fafc;
        border-top-color: rgba(255, 255, 255, 0.12);
      }
      .footer__social-link {
        background: rgba(255, 255, 255, 0.96);
        border-color: rgba(37, 99, 235, 0.35);
        color: #2563eb;
      }
      .footer__social-link:hover,
      .footer__social-link:focus-visible {
        background: rgba(37, 99, 235, 0.15);
        border-color: rgba(37, 99, 235, 0.55);
        color: #1d4ed8;
      }
      .dark .footer__social-link {
        background: rgba(37, 99, 235, 0.25);
        border-color: rgba(59, 130, 246, 0.45);
        color: #fff;
      }
      .footer__contact address {
        color: rgba(15, 23, 42, 0.7);
      }
      .dark .footer__contact address {
        color: rgba(226, 232, 240, 0.75);
      }
      .footer__contact a {
        color: #2563eb;
      }
      .footer__btn--ghost {
        background: rgba(243, 244, 246, 0.9);
        border-color: rgba(148, 163, 184, 0.35);
        color: rgba(15, 23, 42, 0.8);
      }
      .footer__btn--ghost:hover,
      .footer__btn--ghost:focus-visible {
        background: rgba(243, 244, 246, 1);
        border-color: rgba(37, 99, 235, 0.35);
        color: #1d4ed8;
      }
      .footer__bottom {
        border-top: 1px solid rgba(148, 163, 184, 0.4);
        color: rgba(15, 23, 42, 0.65);
      }
      .dark .footer__bottom {
        color: rgba(226, 232, 240, 0.7);
      }
      .footer__quick-links a {
        color: rgba(15, 23, 42, 0.75);
      }
      .footer__quick-links a:hover,
      .footer__quick-links a:focus-visible {
        color: #2563eb;
      }
    }
  </style>
