---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const {
  title = "Inovasore | Desarrollo web, tiendas online y landing pages",
  description = "Creamos páginas web y tiendas online que convierten: landing pages, e-commerce, webs institucionales y plataformas educativas. Diseño moderno, SEO técnico y alto rendimiento.",
  ogTitle = "Desarrollo web y tiendas online que convierten | Inovasore",
  ogDescription = "Impulsa tu presencia digital con sitios rápidos, seguros y optimizados: landing pages, e-commerce, webs institucionales y plataformas educativas. Diseño, SEO técnico y performance para atraer y vender más.",
  ogImage = "/Web-Inovasore.webp",
  navOffset = "5rem",
} = Astro.props;

const siteOrigin = (Astro.site ? new URL(Astro.site).origin : 'https://Inovasore.com');
const pathname = Astro.url?.pathname ?? '/';
const canonical = siteOrigin.replace(/\/$/, '') + pathname;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Webfonts: usa link en vez de @import para mejor rendimiento -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Material Symbols (Google Icons) -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24..48,600,1,0" rel="stylesheet" />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Inovasore" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/webp" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" is:inline>{JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'Inovasore',
      url: siteOrigin,
      sameAs: [
        'https://www.facebook.com/Inovasore',
        'https://www.instagram.com/Inovasore/'
      ],
      logo: siteOrigin + '/Logotipo.svg'
    })}</script>

    <!-- Dark por defecto (si no hay preferencia guardada) -->
    <script is:inline>
      try {
        const root = document.documentElement;
        let t = localStorage.getItem('theme');
        if (t === null) {
          // Respeta prefers-color-scheme en la primera carga
          const prefersLight = window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches;
          t = prefersLight ? 'light' : 'dark';
          localStorage.setItem('theme', t);
        }
        root.classList.toggle('dark', t !== 'light');
      } catch (_) {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>

  <body id="top">
    <Navbar />
    <main style={`padding-top:${navOffset}`}>
      <slot />
    </main>
    <Footer />
    <script is:inline>
      (function () {
        if (window.__InovasoreRevealInitialized) return;
        window.__InovasoreRevealInitialized = true;

        const init = () => {
          const revealEls = document.querySelectorAll('.reveal');
          if (!revealEls.length) return;

          const prefersReduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          if (!('IntersectionObserver' in window) || prefersReduced) {
            revealEls.forEach((el) => el.classList.add('in'));
            return;
          }

          const observer = new IntersectionObserver((entries) => {
            for (const { isIntersecting, target } of entries) {
              if (!isIntersecting) continue;
              target.classList.remove('in');
              void target.offsetWidth;
              requestAnimationFrame(() => target.classList.add('in'));
              observer.unobserve(target);
            }
          }, { threshold: 0.05, rootMargin: '5% 0px -5% 0px' });

          revealEls.forEach((el) => {
            el.classList.remove('in');
            observer.observe(el);
          });
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init, { once: true });
        } else {
          init();
        }
      })();
    </script>
  </body>
</html>




