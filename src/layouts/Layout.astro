---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const {
  title = "Diseño y Desarrollo de Páginas Web en Ambato: E-commerce, Landing Pages y Tiendas Online. | Inovasore",
  description = "Creamos páginas web y tiendas online que convierten: landing pages, e-commerce, webs institucionales y plataformas educativas. Diseño moderno, SEO técnico y alto rendimiento en Ambato y todo Ecuador.",
  ogTitle = "Desarrollo web y tiendas online que convierten | Inovasore",
  ogDescription = "Impulsa tu presencia digital con sitios rápidos, seguros y optimizados: landing pages, e-commerce, webs institucionales y plataformas educativas. Diseño, SEO técnico y performance para atraer y vender más.",
  ogImage = "/Web-Inovasore.webp",
  navOffset = "5rem",
} = Astro.props;

const siteOrigin = Astro.site
  ? new URL(Astro.site).origin
  : "https://Inovasore.com";
const pathname = Astro.url?.pathname ?? "/";
const canonical = siteOrigin.replace(/\/$/, "") + pathname;
const interHref =
  "https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap";
const materialHref =
  "https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24..48,600,1,0&display=swap";
// LocalBusiness Schema para SEO Local, AEO y GEO
const localBusinessSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Inovasore",
  description:
    "Agencia digital especializada en desarrollo web, e-commerce, landing pages y marketing digital en Ambato, Ecuador. Creamos sitios web que convierten con diseño moderno, SEO técnico y alto rendimiento.",
  image: siteOrigin + "/Logotipo.svg",
  logo: siteOrigin + "/Logotipo.svg",
  "@id": siteOrigin,
  url: siteOrigin,
  telephone: "+593961141127",
  email: "disenoweb@inovasore.com",
  priceRange: "$180-$1200",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Rio Patate & Rio Chambo",
    addressLocality: "Ambato",
    addressRegion: "Tungurahua",
    postalCode: "180207",
    addressCountry: "EC",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: -1.2717715287074494,
    longitude: -78.62341846076843,
  },
  openingHoursSpecification: {
    "@type": "OpeningHoursSpecification",
    dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    opens: "08:00",
    closes: "24:00",
  },
  sameAs: [
    "https://www.facebook.com/inovasore.ec",
    "https://www.instagram.com/inovasore/",
    "https://x.com/inovasore",
    "https://wa.me/593961141127",
  ],
  areaServed: [
    {
      "@type": "City",
      name: "Ambato",
      "@id": "https://www.wikidata.org/wiki/Q338450",
    },
    {
      "@type": "Country",
      name: "Ecuador",
      "@id": "https://www.wikidata.org/wiki/Q736",
    },
  ],
  serviceArea: {
    "@type": "GeoCircle",
    geoMidpoint: {
      "@type": "GeoCoordinates",
      latitude: -1.2717715287074494,
      longitude: -78.62341846076843,
    },
    geoRadius: "100000",
  },
});
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="p:domain_verify" content="fafbb18240a0e4aa2cd1dedbbb307a59" />
    <link rel="canonical" href={canonical} />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/Icono.svg" />
    <meta name="theme-color" content="#000000" />

    <!-- Webfonts: link instead of @import for better performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href={interHref} />
    <link id="font-inter" rel="stylesheet" href={interHref} media="print" />
    <noscript><link rel="stylesheet" href={interHref} /></noscript>
    <!-- Material Symbols (Google Icons) -->
    <link rel="preload" as="style" href={materialHref} />
    <link
      id="font-material"
      rel="stylesheet"
      href={materialHref}
      media="print"
    />
    <noscript><link rel="stylesheet" href={materialHref} /></noscript>

    <script is:inline>
      (() => {
        const enableFont = (id) => {
          const el = document.getElementById(id);
          if (!(el instanceof HTMLLinkElement) || el.media !== "print") return;
          el.addEventListener(
            "load",
            () => {
              el.media = "all";
            },
            { once: true },
          );
        };
        enableFont("font-inter");
        enableFont("font-material");
      })();
    </script>

    {
      pathname === "/" && (
        <>
          <link
            rel="preload"
            as="image"
            href="/Vectorbg.svg"
            fetchpriority="high"
          />
          <link
            rel="preload"
            as="image"
            href="/works/work-1.webp"
            imagesizes="(min-width: 1024px) 30vw, 80vw"
            fetchpriority="high"
          />
        </>
      )
    }

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Inovasore" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={new URL(ogImage, siteOrigin).href} />
    <meta property="og:image:type" content="image/png" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={new URL(ogImage, siteOrigin).href} />

    <script
      type="application/ld+json"
      is:inline
      set:html={localBusinessSchema}
    />
  </head>

  <body id="top">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script is:inline>
      (function () {
        if (window.__InovasoreRevealInitialized) return;
        window.__InovasoreRevealInitialized = true;

        const init = () => {
          const revealEls = document.querySelectorAll(".reveal");
          if (!revealEls.length) return;

          const prefersReduced =
            window.matchMedia &&
            window.matchMedia("(prefers-reduced-motion: reduce)").matches;
          if (!("IntersectionObserver" in window) || prefersReduced) {
            revealEls.forEach((el) => el.classList.add("in"));
            return;
          }

          const observer = new IntersectionObserver(
            (entries) => {
              for (const { isIntersecting, target } of entries) {
                if (!isIntersecting) continue;
                target.classList.remove("in");
                requestAnimationFrame(() => {
                  target.classList.add("in");
                });
                observer.unobserve(target);
              }
            },
            { threshold: 0.05, rootMargin: "5% 0px -5% 0px" },
          );

          revealEls.forEach((el) => {
            el.classList.remove("in");
            observer.observe(el);
          });
        };

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", init, { once: true });
        } else {
          init();
        }
      })();
    </script>
  </body>
</html>
