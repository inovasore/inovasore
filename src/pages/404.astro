---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 | Inovasore" description="Página no encontrada">
  <section style="padding: 5rem 0; min-height: 60vh; text-align:center">
    <div style="width:clamp(280px,92vw,900px);margin:0 auto;padding:0 16px;">
      <h1 style="font-size:clamp(2rem,3.2vw+1rem,3rem);font-weight:600;margin-bottom:.5rem">Página no encontrada</h1>
      <p style="color:var(--color-text-muted,#6b7280);max-width:70ch;margin:0 auto 2rem">
        Lo sentimos, no pudimos encontrar lo que buscas.
      </p>
      <a href="/" class="btn">Volver al inicio</a>
    </div>
  </section>
</Layout>

