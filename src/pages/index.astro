---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Mission from "../components/Mission.astro";
import WhyUs from "../components/WhyUs.astro";
import Services from "../components/Services.astro";
import Process from "../components/Process.astro";
import Projects from "../components/Projects.astro";
import CTA from "../components/CTA.astro";
import DiscountBanner from "../components/DiscountBanner.astro";
import FAQ from "../components/FAQ.astro";
import { faqs } from "../data/faqs";

// FAQ Schema para AEO (Answer Engine Optimization)
const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
});
---

<Layout
  title="Inovasore | Diseño y Desarrollo de Páginas Web en Ambato: E-commerce, Landing Pages y Tiendas Online."
  description="Creamos páginas web y tiendas online que convierten: landing pages, e-commerce, webs institucionales y plataformas educativas. Diseño moderno, SEO técnico y alto rendimiento en Ambato y todo Ecuador."
  ogTitle="Desarrollo web y tiendas online que convierten | Inovasore"
  ogDescription="Impulsa tu presencia digital con sitios rápidos, seguros y optimizados: landing pages, e-commerce, webs institucionales y plataformas educativas. Diseño, SEO técnico y performance para atraer y vender más."
  ogImage="/Web-Inovasore.webp"
>
  <Hero />
  <div class="shared-bg-wrapper">
    <Mission />
    <Services />
  </div>
  <Process />
  <Projects />
  <CTA />
  <DiscountBanner />
  <WhyUs />
  <FAQ />

  <!-- FAQ Schema para AEO (Answer Engine Optimization) -->
  <script type="application/ld+json" set:html={faqSchema} />
</Layout>

<style>
  .shared-bg-wrapper {
    position: relative;
    background-color: var(--color-bg);
    overflow: hidden;
  }

  .shared-bg-wrapper > :global(*) {
    position: relative;
    z-index: 1;
  }

  /* Extra padding for FAQ component */
  :global(.faq) {
    padding-top: clamp(80px, 12vh, 120px) !important;
    padding-bottom: clamp(100px, 14vh, 140px) !important;
  }

  /* Reduce padding for Process component in home page */
  :global(.process) {
    padding-top: clamp(30px, 4vh, 50px) !important;
  }
</style>
