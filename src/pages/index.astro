---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Mission from "../components/Mission.astro";
import WhyUs from "../components/WhyUs.astro";
import Services from "../components/Services.astro";
import Process from "../components/Process.astro";
import Projects from "../components/Projects.astro";
import CTA from "../components/CTA.astro";
import DiscountBanner from "../components/DiscountBanner.astro";
import FAQ from "../components/FAQ.astro";
---

<Layout
  title="Inovasore | Diseño de Páginas Web en Ambato: E-commerce, Landing Pages y Tiendas Online."
  description="Creamos páginas web y tiendas online que convierten: landing pages, e-commerce, webs institucionales y plataformas educativas. Diseño moderno, SEO técnico y alto rendimiento."
  ogTitle="Desarrollo web y tiendas online que convierten | Inovasore"
  ogDescription="Impulsa tu presencia digital con sitios rápidos, seguros y optimizados: landing pages, e-commerce, webs institucionales y plataformas educativas. Diseño, SEO técnico y performance para atraer y vender más."
  ogImage="/Web-Novasore.webp"
>
  <Hero />
  <div class="shared-bg-wrapper">
    <Mission />
    <Services />
  </div>
  <Process />
  <Projects />
  <CTA />
  <DiscountBanner />
  <WhyUs />
  <FAQ />
</Layout>

<style>
  .shared-bg-wrapper {
    position: relative;
    background-color: var(--color-bg);
    overflow: hidden;
  }

  .shared-bg-wrapper > :global(*) {
    position: relative;
    z-index: 1;
  }
</style>
