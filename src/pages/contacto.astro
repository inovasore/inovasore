---
import Layout from "../layouts/Layout.astro";
import ContactPanel from "../components/ContactPanel.astro";
---

<Layout title="Contacto | Inovasore" description="Ponte en contacto con nosotros para tu próximo proyecto.">
  <section class="contact-page-hero">
    <div class="section-inner section-inner--center contact-page-hero__inner">
      <div class="section-tag contact-page-hero__tag">Contáctanos</div>
      <h1 class="contact-page-hero__title">
        Agenda una llamada o <span class="highlight">escríbenos hoy mismo.</span>
      </h1>
      <p class="contact-page-hero__subtitle">
        ¿Tienes un proyecto en mente? Cuéntanos más sobre él y descubre cómo podemos ayudarte. También puedes
        escribirnos a
        <a href="mailto:info@inovasore.com">info@inovasore.com</a>.
      </p>
    </div>
  </section>

  <ContactPanel />
</Layout>

<style>
  .contact-page-hero {
    padding: var(--section-padding-y) 0;
    color: var(--color-text);
  }

  .contact-page-hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(12px, 2.4vh, 18px);
  }

  .contact-page-hero__title {
    margin: clamp(4px, 2.4vh, 8px) auto clamp(4px, 2.4vh, 8px);
    max-width: 28ch;
    font-size: clamp(1.8rem, 3.2vw + 0.6rem, 2.5rem);
    font-weight: 600;
    line-height: 1.15;
    text-wrap: balance;
  }

  .contact-page-hero__title .highlight {
    display: inline-block;
    background-image: linear-gradient(90deg, #26d2f8, #23b2ff, #0973e1 70%, #3b5bff 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
  }

  .contact-page-hero__subtitle {
    margin: 0 auto clamp(4px, 6vh, 8px);
    max-width: 60ch;
    font-size: clamp(1rem, 0.9rem + 0.35vw, 1.15rem);
    font-weight: 300;
    color: color-mix(in oklab, var(--color-text) 60%, transparent);
  }

  .contact-page-hero__subtitle a {
    color: inherit;
    font-weight: 500;
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, currentColor 40%, transparent);
  }

  .contact-page-hero__subtitle a:hover,
  .contact-page-hero__subtitle a:focus-visible {
    color: var(--color-primary);
    border-color: color-mix(in oklab, var(--color-primary) 60%, transparent);
  }
</style>
